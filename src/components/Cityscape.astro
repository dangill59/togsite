      <rect x="1040" y="95" width="45" height="205" fill="var(--city-color)"/>
      <rect x="1110" y="125" width="55" height="175" fill="var(--city-color)"/>
      <rect x="1190" y="150" width="30" height="150" fill="var(--city-color)"/>
      <rect x="1240" y="80" width="45" height="220" fill="var(--city-color)"/>
      <rect x="1310" y="140" width="40" height="160" fill="var(--city-color)"/>
      <rect x="1380" y="100" width="50" height="200" fill="var(--city-color)"/>
      <rect x="1460" y="130" width="35" height="170" fill="var(--city-color)"/>
      <rect x="1520" y="110" width="55" height="190" fill="var(--city-color)"/>
