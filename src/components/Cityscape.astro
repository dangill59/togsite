  </svg>
</div>

<style>
  .cityscape {
    position: absolute;
    left: 0;
    right: 0;
    width: 100%;
    pointer-events: none;
    opacity: var(--city-opacity);
    z-index: 0;
  }

  .city-bottom {
    bottom: 0;
  }

  .city-top {
    top: 0;
    transform: scaleY(-1);
  }

  .city-svg {
    width: 100%;
    height: 250px;
    display: block;
  }

  @media (max-width: 768px) {
    .city-svg { height: 150px; }
  }
</style>
