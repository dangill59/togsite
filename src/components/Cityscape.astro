      <rect x="640" y="110" width="50" height="190" fill="var(--city-color)"/>
      <rect x="650" y="95" width="30" height="15" fill="var(--city-color)"/>
      <rect x="705" y="175" width="65" height="125" fill="var(--city-color)"/>
      <rect x="785" y="85" width="55" height="215" fill="var(--city-color)"/>
