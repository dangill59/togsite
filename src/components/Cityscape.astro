---
interface Props {
  color?: string;
  position?: 'bottom' | 'top';
  opacity?: number;
}

const { color = '#2a1a0e', position = 'bottom', opacity = 0.25 } = Astro.props;
---

<div class:list={['cityscape', `city-${position}`]} style={`--city-color: ${color}; --city-opacity: ${opacity};`}>
  <svg viewBox="0 0 1600 300" preserveAspectRatio="none" class="city-svg">
    <!-- Far buildings (shorter, darker) -->
    <g opacity="0.5">
      <rect x="20" y="140" width="45" height="160" fill="var(--city-color)"/>
      <rect x="80" y="100" width="35" height="200" fill="var(--city-color)"/>
      <rect x="130" y="160" width="50" height="140" fill="var(--city-color)"/>
      <rect x="200" y="80" width="30" height="220" fill="var(--city-color)"/>
      <rect x="260" y="130" width="55" height="170" fill="var(--city-color)"/>
