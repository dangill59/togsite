      <rect x="1085" y="90" width="4" height="5"/><rect x="1065" y="105" width="4" height="5"/>
      <rect x="1085" y="105" width="4" height="5"/><rect x="1075" y="120" width="4" height="5"/>
      <rect x="1395" y="110" width="4" height="5"/><rect x="1405" y="110" width="4" height="5"/>
      <rect x="1415" y="110" width="4" height="5"/><rect x="1395" y="125" width="4" height="5"/>
      <rect x="1415" y="125" width="4" height="5"/><rect x="1405" y="140" width="4" height="5"/>
      <rect x="650" y="125" width="4" height="5"/><rect x="660" y="125" width="4" height="5"/>
      <rect x="670" y="125" width="4" height="5"/><rect x="650" y="140" width="4" height="5"/>
      <rect x="670" y="140" width="4" height="5"/>
      <rect x="925" y="135" width="4" height="5"/><rect x="935" y="135" width="4" height="5"/>
      <rect x="945" y="135" width="4" height="5"/><rect x="955" y="135" width="4" height="5"/>
      <rect x="925" y="150" width="4" height="5"/><rect x="945" y="150" width="4" height="5"/>
