---
// P - Drums & Vocals - African American intellectual
// Superpower: The Cerebral Beat - drumming so intellectual it generates equations and enlightenment
---

<div class="character p-char">
  <div class="power-effects">
    <span class="equation eq1">E=mc&sup2;</span>
    <span class="equation eq2">&pi;r&sup2;</span>
    <span class="equation eq3">&radic;2</span>
    <span class="equation eq4">&Sigma;f(x)</span>
    <span class="equation eq5">&infin;</span>
    <span class="equation eq6">&Delta;t</span>
    <span class="equation eq7">&#966;</span>
    <div class="brain-wave bw1"></div>
    <div class="brain-wave bw2"></div>
    <div class="brain-wave bw3"></div>
    <div class="enlighten-glow"></div>
  </div>
  <svg viewBox="0 0 300 400" class="char-svg">
    <!-- Ground shadow -->
    <ellipse cx="150" cy="385" rx="80" ry="12" fill="rgba(0,0,0,0.15)"/>

    <!-- Drum stool hint -->
    <rect x="120" y="345" width="60" height="8" rx="4" fill="#666"/>
    <line x1="130" y1="353" x2="125" y2="385" stroke="#666" stroke-width="3"/>
    <line x1="170" y1="353" x2="175" y2="385" stroke="#666" stroke-width="3"/>

    <!-- Legs - sharp trousers -->
    <rect x="115" y="290" width="28" height="60" rx="6" fill="#1a1a1a"/>
    <rect x="157" y="290" width="28" height="60" rx="6" fill="#1a1a1a"/>

    <!-- Clean shoes -->
    <rect x="108" y="342" width="40" height="16" rx="8" fill="#3a3a3a"/>
    <rect x="152" y="342" width="40" height="16" rx="8" fill="#3a3a3a"/>

    <!-- Body - sharp jacket/vest -->
    <rect x="90" y="175" width="120" height="125" rx="18" fill="#2c2c54"/>

    <!-- Vest/waistcoat -->
    <path d="M105,178 L105,290 L145,290 L145,200 Z" fill="#1a1a3e"/>
    <path d="M195,178 L195,290 L155,290 L155,200 Z" fill="#1a1a3e"/>
    <line x1="150" y1="200" x2="150" y2="290" stroke="#2c2c54" stroke-width="2"/>

    <!-- Shirt collar + tie -->
    <path d="M130,178 L150,200 L170,178" fill="white"/>
    <polygon points="147,200 150,280 153,200" fill="#c0392b"/>
    <polygon points="145,198 150,208 155,198" fill="#c0392b"/>

    <!-- Left arm - stick up -->
    <g class="arm-left-group">
      <rect x="48" y="175" width="30" height="85" rx="10" fill="#8D5524" transform="rotate(-20, 63, 175)"/>
      <!-- Drumstick left -->
      <rect x="25" y="125" width="5" height="80" rx="2" fill="#DEB887" transform="rotate(-20, 28, 165)"/>
      <ellipse cx="27" cy="125" rx="4" ry="5" fill="#DEB887" transform="rotate(-20, 28, 125)"/>
    </g>

    <!-- Right arm - stick down -->
    <g class="arm-right-group">
      <rect x="222" y="180" width="30" height="85" rx="10" fill="#8D5524" transform="rotate(15, 237, 180)"/>
      <!-- Drumstick right -->
      <rect x="248" y="140" width="5" height="80" rx="2" fill="#DEB887" transform="rotate(15, 250, 180)"/>
      <ellipse cx="250" cy="140" rx="4" ry="5" fill="#DEB887" transform="rotate(15, 250, 140)"/>
    </g>

    <!-- Snare drum hint (in front) -->
    <ellipse cx="150" cy="300" rx="55" ry="15" fill="#C0C0C0"/>
    <rect x="95" y="290" width="110" height="12" rx="2" fill="#DCDCDC"/>
    <ellipse cx="150" cy="290" rx="55" ry="15" fill="#E8E8E8"/>
    <line x1="100" y1="290" x2="100" y2="302" stroke="#C0C0C0" stroke-width="1"/>
    <line x1="120" y1="288" x2="120" y2="302" stroke="#C0C0C0" stroke-width="1"/>
    <line x1="140" y1="287" x2="140" y2="302" stroke="#C0C0C0" stroke-width="1"/>
    <line x1="160" y1="287" x2="160" y2="302" stroke="#C0C0C0" stroke-width="1"/>
    <line x1="180" y1="288" x2="180" y2="302" stroke="#C0C0C0" stroke-width="1"/>
    <line x1="200" y1="290" x2="200" y2="302" stroke="#C0C0C0" stroke-width="1"/>

    <!-- Neck -->
    <rect x="130" y="150" width="40" height="30" rx="10" fill="#8D5524"/>

    <!-- Head -->
    <ellipse cx="150" cy="110" rx="48" ry="55" fill="#8D5524"/>

    <!-- Goatee -->
    <path d="M138,135 Q150,160 162,135" fill="#1a1a1a"/>
    <path d="M140,132 L140,142 Q150,150 160,142 L160,132" fill="#1a1a1a"/>

    <!-- Mouth - cool smirk -->
    <path d="M135,130 Q150,138 165,132" stroke="#5a3015" stroke-width="2" fill="none" stroke-linecap="round"/>

    <!-- Nose -->
    <ellipse cx="150" cy="116" rx="8" ry="6" fill="#7A4A1E"/>

    <!-- Eyes - sharp and knowing -->
    <ellipse cx="130" cy="98" rx="10" ry="9" fill="white"/>
    <ellipse cx="170" cy="98" rx="10" ry="9" fill="white"/>
    <circle cx="132" cy="98" r="5" fill="#3d2b1f"/>
    <circle cx="172" cy="98" r="5" fill="#3d2b1f"/>
    <circle cx="133" cy="97" r="2.5" fill="#1a1a1a"/>
    <circle cx="173" cy="97" r="2.5" fill="#1a1a1a"/>
    <circle cx="134" cy="96" r="1" fill="white"/>
    <circle cx="174" cy="96" r="1" fill="white"/>

    <!-- Eyebrows - one slightly raised (the intellectual look) -->
    <path d="M118,87 Q130,80 142,86" stroke="#1a1a1a" stroke-width="3.5" fill="none" stroke-linecap="round"/>
    <path d="M158,84 Q170,78 182,85" stroke="#1a1a1a" stroke-width="3.5" fill="none" stroke-linecap="round"/>

    <!-- Glasses - sharp rectangular frames -->
    <rect x="116" y="89" width="28" height="20" rx="3" fill="none" stroke="#1a1a1a" stroke-width="2.5"/>
    <rect x="156" y="89" width="28" height="20" rx="3" fill="none" stroke="#1a1a1a" stroke-width="2.5"/>
    <line x1="144" y1="98" x2="156" y2="98" stroke="#1a1a1a" stroke-width="2"/>
    <line x1="116" y1="98" x2="105" y2="94" stroke="#1a1a1a" stroke-width="2"/>
    <line x1="184" y1="98" x2="195" y2="94" stroke="#1a1a1a" stroke-width="2"/>

    <!-- Clean fade haircut -->
    <path d="M102,88 Q102,48 130,38 Q150,32 170,38 Q198,48 198,88" fill="#1a1a1a"/>
    <path d="M105,95 Q102,60 120,45" fill="#1a1a1a"/>
    <path d="M195,95 Q198,60 180,45" fill="#1a1a1a"/>
    <!-- Tight top -->
    <path d="M108,85 Q110,55 150,45 Q190,55 192,85" fill="#2a2a2a"/>
  </svg>
  <div class="char-name">P</div>
  <div class="char-power">The Cerebral Beat</div>
  <div class="char-desc">Drumming so intellectual it solves quantum equations mid-fill. The rhythm is the proof.</div>
</div>

<style>
  .p-char {
    position: relative;
    text-align: center;
    max-width: 320px;
  }

  .char-svg {
    width: 100%;
    max-width: 280px;
    filter: drop-shadow(3px 3px 0 rgba(0,0,0,0.2));
    position: relative;
    z-index: 2;
  }

  .char-name {
    font-family: var(--comic);
    font-size: 2.2rem;
    color: var(--brown);
    letter-spacing: 4px;
    text-shadow: 2px 2px 0 rgba(0,0,0,0.15);
    margin-top: 0.25rem;
  }

  .char-power {
    font-family: var(--comic);
    font-size: 1rem;
    color: #2c2c54;
    letter-spacing: 2px;
    text-transform: uppercase;
  }

  .char-desc {
    font-size: 0.9rem;
    opacity: 0.7;
    margin-top: 0.5rem;
    max-width: 260px;
    margin-left: auto;
    margin-right: auto;
  }

  .power-effects {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 3;
  }

  .equation {
    position: absolute;
    font-family: 'Georgia', serif;
    font-style: italic;
    font-size: 1rem;
    color: #2c2c54;
    opacity: 0;
    animation: equationFloat 5s ease-in-out infinite;
  }

  .eq1 { left: 0%; top: 10%; animation-delay: 0s; font-size: 1.1rem; }
  .eq2 { right: 2%; top: 20%; animation-delay: 0.7s; }
  .eq3 { left: 5%; top: 35%; animation-delay: 1.4s; font-size: 1.3rem; }
  .eq4 { right: 0%; top: 45%; animation-delay: 2.1s; font-size: 0.9rem; }
  .eq5 { left: 8%; top: 5%; animation-delay: 2.8s; font-size: 1.5rem; }
  .eq6 { right: 8%; top: 8%; animation-delay: 3.5s; }
  .eq7 { left: 2%; top: 25%; animation-delay: 4.2s; font-size: 1.4rem; }

  @keyframes equationFloat {
    0% { opacity: 0; transform: translateY(10px) scale(0.7); }
    10% { opacity: 0.7; transform: translateY(0) scale(1); }
    40% { opacity: 0.7; }
    50% { opacity: 0; transform: translateY(-30px) scale(1.1); }
    100% { opacity: 0; }
  }

  .brain-wave {
    position: absolute;
    left: 50%;
    top: 12%;
    width: 30px;
    height: 30px;
    border: 2px solid #9b59b6;
    border-radius: 50%;
    opacity: 0;
    animation: brainPulse 3s ease-out infinite;
  }

  .bw2 { animation-delay: 1s; }
  .bw3 { animation-delay: 2s; }

  @keyframes brainPulse {
    0% { transform: translate(-50%, 0) scale(0.3); opacity: 0.6; }
    100% { transform: translate(-50%, 0) scale(5); opacity: 0; }
  }

  .enlighten-glow {
    position: absolute;
    left: 50%;
    top: 8%;
    width: 80px;
    height: 80px;
    background: radial-gradient(circle, rgba(155, 89, 182, 0.2) 0%, transparent 70%);
    border-radius: 50%;
    transform: translateX(-50%);
    animation: glowPulse 2s ease-in-out infinite;
  }

  @keyframes glowPulse {
    0%, 100% { opacity: 0.5; transform: translateX(-50%) scale(1); }
    50% { opacity: 1; transform: translateX(-50%) scale(1.3); }
  }

  .arm-left-group {
    animation: drumHitLeft 0.6s ease-in-out infinite;
    transform-origin: 63px 175px;
  }

  .arm-right-group {
    animation: drumHitRight 0.6s ease-in-out infinite;
    transform-origin: 237px 180px;
  }

  @keyframes drumHitLeft {
    0%, 100% { transform: rotate(0deg); }
    30% { transform: rotate(8deg); }
    50% { transform: rotate(-5deg); }
  }

  @keyframes drumHitRight {
    0%, 100% { transform: rotate(0deg); }
    50% { transform: rotate(-6deg); }
    80% { transform: rotate(4deg); }
  }
</style>
