---
interface Props {
  color?: string;
  opacity?: number;
}
const { color = '#5c3317', opacity = 0.07 } = Astro.props;
---

<div class="speed-lines" style={`--sl-color: ${color}; --sl-opacity: ${opacity};`}>
  <svg viewBox="0 0 800 600" preserveAspectRatio="none">
    <g stroke="var(--sl-color)" stroke-width="1.5" opacity="var(--sl-opacity)">
      <line x1="400" y1="300" x2="-50" y2="-20"/>
      <line x1="400" y1="300" x2="0" y2="-30"/>
      <line x1="400" y1="300" x2="50" y2="-25"/>
      <line x1="400" y1="300" x2="120" y2="-10"/>
      <line x1="400" y1="300" x2="200" y2="-15"/>
      <line x1="400" y1="300" x2="300" y2="-5"/>
      <line x1="400" y1="300" x2="500" y2="-5"/>
      <line x1="400" y1="300" x2="600" y2="-15"/>
      <line x1="400" y1="300" x2="680" y2="-10"/>
      <line x1="400" y1="300" x2="750" y2="-25"/>
      <line x1="400" y1="300" x2="800" y2="-30"/>
      <line x1="400" y1="300" x2="850" y2="-20"/>
      <line x1="400" y1="300" x2="850" y2="80"/>
      <line x1="400" y1="300" x2="860" y2="180"/>
      <line x1="400" y1="300" x2="860" y2="300"/>
      <line x1="400" y1="300" x2="860" y2="420"/>
      <line x1="400" y1="300" x2="850" y2="520"/>
      <line x1="400" y1="300" x2="850" y2="620"/>
      <line x1="400" y1="300" x2="750" y2="625"/>
      <line x1="400" y1="300" x2="600" y2="615"/>
      <line x1="400" y1="300" x2="500" y2="605"/>
      <line x1="400" y1="300" x2="300" y2="605"/>
      <line x1="400" y1="300" x2="200" y2="615"/>
      <line x1="400" y1="300" x2="50" y2="625"/>
      <line x1="400" y1="300" x2="-50" y2="620"/>
      <line x1="400" y1="300" x2="-60" y2="520"/>
      <line x1="400" y1="300" x2="-60" y2="420"/>
      <line x1="400" y1="300" x2="-60" y2="300"/>
      <line x1="400" y1="300" x2="-60" y2="180"/>
      <line x1="400" y1="300" x2="-50" y2="80"/>
    </g>
  </svg>
</div>

<style>
  .speed-lines {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    overflow: hidden;
  }

  .speed-lines svg {
    width: 100%;
    height: 100%;
  }
</style>
