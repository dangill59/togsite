---
// Darby - Bass & Vocals - Irish powerhouse
// Superpower: The Shamrock Shakedown - bass so heavy the ground cracks and shamrocks erupt
---

<div class="character darby">
  <div class="power-effects">
    <span class="shamrock s1">&#9752;</span>
    <span class="shamrock s2">&#9752;</span>
    <span class="shamrock s3">&#9752;</span>
    <span class="shamrock s4">&#9752;</span>
    <span class="shamrock s5">&#9752;</span>
    <span class="shamrock s6">&#9752;</span>
    <div class="ground-crack"></div>
    <div class="ground-crack crack2"></div>
    <div class="bass-wave bw1"></div>
    <div class="bass-wave bw2"></div>
    <div class="bass-wave bw3"></div>
  </div>
  <img src="/darby.png" alt="Darby - Bass & Vocals" class="char-img" />
  <div class="char-name">DARBY</div>
  <div class="char-power">The Shamrock Shakedown</div>
  <div class="char-desc">Bass so heavy the ground cracks and shamrocks erupt from the earth. Slainte!</div>
</div>

<style>
  .darby {
    position: relative;
    text-align: center;
    max-width: 320px;
  }

  .char-img {
    width: 100%;
    max-width: 280px;
    margin: 0 auto;
    filter: drop-shadow(3px 3px 0 rgba(0,0,0,0.2));
    position: relative;
    z-index: 2;
  }

  .char-name {
    font-family: var(--comic);
    font-size: 2.2rem;
    color: var(--brown);
    letter-spacing: 4px;
    text-shadow: 2px 2px 0 rgba(0,0,0,0.15);
    margin-top: 0.25rem;
  }

  .char-power {
    font-family: var(--comic);
    font-size: 1rem;
    color: #2d5a27;
    letter-spacing: 2px;
    text-transform: uppercase;
  }

  .char-desc {
    font-size: 0.9rem;
    opacity: 0.7;
    margin-top: 0.5rem;
    max-width: 260px;
    margin-left: auto;
    margin-right: auto;
  }

  .power-effects {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 3;
  }

  .shamrock {
    position: absolute;
    color: #2d5a27;
    font-size: 1.8rem;
    animation: shamrockFloat 3s ease-in-out infinite;
    opacity: 0;
  }

  .s1 { left: 5%; top: 40%; animation-delay: 0s; }
  .s2 { right: 8%; top: 30%; animation-delay: 0.5s; }
  .s3 { left: 15%; top: 15%; animation-delay: 1s; }
  .s4 { right: 15%; top: 55%; animation-delay: 1.5s; }
  .s5 { left: 0%; top: 60%; animation-delay: 2s; font-size: 1.2rem; }
  .s6 { right: 2%; top: 10%; animation-delay: 2.5s; font-size: 1.4rem; }

  @keyframes shamrockFloat {
    0% { opacity: 0; transform: translateY(20px) rotate(0deg) scale(0.5); }
    20% { opacity: 1; }
    80% { opacity: 1; }
    100% { opacity: 0; transform: translateY(-60px) rotate(360deg) scale(1.2); }
  }

  .ground-crack {
    position: absolute;
    bottom: 8%;
    left: 20%;
    width: 60%;
    height: 3px;
    background: #8B4513;
    animation: crack 2s ease-in-out infinite;
    transform-origin: center;
  }

  .crack2 {
    left: 30%;
    width: 40%;
    bottom: 6%;
    animation-delay: 1s;
    transform: rotate(15deg);
  }

  @keyframes crack {
    0%, 100% { opacity: 0.3; transform: scaleX(0.8); }
    50% { opacity: 0.8; transform: scaleX(1.1); }
  }

  .bass-wave {
    position: absolute;
    left: 50%;
    top: 55%;
    width: 60px;
    height: 60px;
    border: 3px solid #2d5a27;
    border-radius: 50%;
    transform: translate(-50%, -50%) scale(0);
    opacity: 0;
    animation: bassWave 2s ease-out infinite;
  }

  .bw2 { animation-delay: 0.6s; }
  .bw3 { animation-delay: 1.2s; }

  @keyframes bassWave {
    0% { transform: translate(-50%, -50%) scale(0); opacity: 0.6; }
    100% { transform: translate(-50%, -50%) scale(4); opacity: 0; }
  }
</style>
