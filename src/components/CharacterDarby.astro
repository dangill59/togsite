---
// Darby - Bass & Vocals - Irish powerhouse
// Superpower: The Shamrock Shakedown - bass so heavy the ground cracks and shamrocks erupt
---

<div class="character darby">
  <div class="power-effects">
    <span class="shamrock s1">&#9752;</span>
    <span class="shamrock s2">&#9752;</span>
    <span class="shamrock s3">&#9752;</span>
    <span class="shamrock s4">&#9752;</span>
    <span class="shamrock s5">&#9752;</span>
    <span class="shamrock s6">&#9752;</span>
    <div class="ground-crack"></div>
    <div class="ground-crack crack2"></div>
    <div class="bass-wave bw1"></div>
    <div class="bass-wave bw2"></div>
    <div class="bass-wave bw3"></div>
  </div>
  <svg viewBox="0 0 300 400" class="char-svg">
    <!-- Ground shadow -->
    <ellipse cx="150" cy="385" rx="80" ry="12" fill="rgba(0,0,0,0.15)"/>

    <!-- Legs - sturdy stance -->
    <rect x="105" y="295" width="32" height="85" rx="8" fill="#2d5a27" class="leg-left"/>
    <rect x="163" y="295" width="32" height="85" rx="8" fill="#2d5a27" class="leg-right"/>

    <!-- Boots - big stompers -->
    <rect x="95" y="365" width="50" height="22" rx="10" fill="#1a1a1a"/>
    <rect x="155" y="365" width="50" height="22" rx="10" fill="#1a1a1a"/>

    <!-- Body - barrel chested -->
    <rect x="85" y="180" width="130" height="130" rx="20" fill="#2d5a27"/>

    <!-- Belt with buckle -->
    <rect x="85" y="290" width="130" height="14" rx="3" fill="#8B4513"/>
    <rect x="135" y="287" width="30" height="20" rx="3" fill="#DAA520"/>
    <text x="150" y="302" text-anchor="middle" font-size="11" fill="#2d5a27" font-weight="bold">&#9752;</text>

    <!-- Shirt detail - henley -->
    <line x1="150" y1="195" x2="150" y2="245" stroke="#1a4a15" stroke-width="2"/>
    <circle cx="150" cy="205" r="3" fill="#DAA520"/>
    <circle cx="150" cy="220" r="3" fill="#DAA520"/>
    <circle cx="150" cy="235" r="3" fill="#DAA520"/>

    <!-- Left arm holding bass neck -->
    <rect x="55" y="200" width="35" height="90" rx="12" fill="#FDBCB4" class="arm-left"/>
    <!-- Right arm on bass body -->
    <rect x="210" y="210" width="35" height="85" rx="12" fill="#FDBCB4" class="arm-right"/>

    <!-- Bass guitar -->
    <g class="bass-guitar">
      <rect x="40" y="130" width="12" height="180" rx="4" fill="#8B4513"/>
      <ellipse cx="220" cy="270" rx="45" ry="55" fill="#c0392b"/>
      <ellipse cx="220" cy="270" rx="35" ry="45" fill="#e74c3c"/>
      <circle cx="220" cy="260" r="8" fill="#1a1a1a"/>
      <circle cx="220" cy="280" r="8" fill="#1a1a1a"/>
      <rect x="45" y="128" width="8" height="4" rx="2" fill="#DAA520"/>
      <rect x="45" y="138" width="8" height="4" rx="2" fill="#DAA520"/>
      <rect x="45" y="148" width="8" height="4" rx="2" fill="#DAA520"/>
      <rect x="45" y="158" width="8" height="4" rx="2" fill="#DAA520"/>
      <!-- Strings -->
      <line x1="44" y1="130" x2="195" y2="250" stroke="#DAA520" stroke-width="1.5"/>
      <line x1="47" y1="130" x2="200" y2="255" stroke="#DAA520" stroke-width="1.5"/>
      <line x1="50" y1="130" x2="205" y2="260" stroke="#C0C0C0" stroke-width="1"/>
      <line x1="53" y1="130" x2="210" y2="265" stroke="#C0C0C0" stroke-width="1"/>
    </g>

    <!-- Neck -->
    <rect x="125" y="155" width="50" height="35" rx="10" fill="#FDBCB4"/>

    <!-- Head -->
    <ellipse cx="150" cy="120" rx="55" ry="60" fill="#FDBCB4"/>

    <!-- Big red beard -->
    <ellipse cx="150" cy="155" rx="48" ry="35" fill="#B7410E"/>
    <ellipse cx="150" cy="145" rx="45" ry="28" fill="#D2691E"/>
    <path d="M105,135 Q110,170 120,180 Q150,195 180,180 Q190,170 195,135" fill="#D2691E"/>

    <!-- Mouth (singing!) -->
    <ellipse cx="150" cy="140" rx="12" ry="8" fill="#1a1a1a"/>
    <ellipse cx="150" cy="137" rx="8" ry="4" fill="#c0392b"/>

    <!-- Nose -->
    <ellipse cx="150" cy="118" rx="8" ry="6" fill="#F0A090"/>

    <!-- Eyes - wild and happy -->
    <ellipse cx="128" cy="100" rx="12" ry="10" fill="white"/>
    <ellipse cx="172" cy="100" rx="12" ry="10" fill="white"/>
    <circle cx="130" cy="100" r="6" fill="#2e8b57"/>
    <circle cx="174" cy="100" r="6" fill="#2e8b57"/>
    <circle cx="131" cy="99" r="3" fill="#1a1a1a"/>
    <circle cx="175" cy="99" r="3" fill="#1a1a1a"/>
    <circle cx="133" cy="97" r="1.5" fill="white"/>
    <circle cx="177" cy="97" r="1.5" fill="white"/>

    <!-- Eyebrows - expressive -->
    <path d="M115,85 Q128,78 142,87" stroke="#8B4513" stroke-width="4" fill="none" stroke-linecap="round"/>
    <path d="M158,87 Q172,78 185,85" stroke="#8B4513" stroke-width="4" fill="none" stroke-linecap="round"/>

    <!-- Wild red hair -->
    <path d="M95,95 Q85,50 110,40 Q130,25 150,30 Q170,25 190,40 Q215,50 205,95" fill="#D2691E"/>
    <path d="M95,95 Q80,70 100,55 Q90,40 115,35" fill="#D2691E"/>
    <path d="M205,95 Q220,70 200,55 Q210,40 185,35" fill="#D2691E"/>

    <!-- Flat cap -->
    <ellipse cx="150" cy="62" rx="62" ry="15" fill="#3a3a3a"/>
    <path d="M88,62 Q90,40 150,35 Q210,40 212,62" fill="#4a4a4a"/>
    <rect x="85" y="58" width="130" height="8" rx="4" fill="#3a3a3a"/>
  </svg>
  <div class="char-name">DARBY</div>
  <div class="char-power">The Shamrock Shakedown</div>
  <div class="char-desc">Bass so heavy the ground cracks and shamrocks erupt from the earth. Slainte!</div>
</div>

<style>
  .darby {
    position: relative;
    text-align: center;
    max-width: 320px;
  }

  .char-svg {
    width: 100%;
    max-width: 280px;
    filter: drop-shadow(3px 3px 0 rgba(0,0,0,0.2));
    position: relative;
    z-index: 2;
  }

  .char-name {
    font-family: var(--comic);
    font-size: 2.2rem;
    color: var(--brown);
    letter-spacing: 4px;
    text-shadow: 2px 2px 0 rgba(0,0,0,0.15);
    margin-top: 0.25rem;
  }

  .char-power {
    font-family: var(--comic);
    font-size: 1rem;
    color: #2d5a27;
    letter-spacing: 2px;
    text-transform: uppercase;
  }

  .char-desc {
    font-size: 0.9rem;
    opacity: 0.7;
    margin-top: 0.5rem;
    max-width: 260px;
    margin-left: auto;
    margin-right: auto;
  }

  .power-effects {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 3;
  }

  .shamrock {
    position: absolute;
    color: #2d5a27;
    font-size: 1.8rem;
    animation: shamrockFloat 3s ease-in-out infinite;
    opacity: 0;
  }

  .s1 { left: 5%; top: 40%; animation-delay: 0s; }
  .s2 { right: 8%; top: 30%; animation-delay: 0.5s; }
  .s3 { left: 15%; top: 15%; animation-delay: 1s; }
  .s4 { right: 15%; top: 55%; animation-delay: 1.5s; }
  .s5 { left: 0%; top: 60%; animation-delay: 2s; font-size: 1.2rem; }
  .s6 { right: 2%; top: 10%; animation-delay: 2.5s; font-size: 1.4rem; }

  @keyframes shamrockFloat {
    0% { opacity: 0; transform: translateY(20px) rotate(0deg) scale(0.5); }
    20% { opacity: 1; }
    80% { opacity: 1; }
    100% { opacity: 0; transform: translateY(-60px) rotate(360deg) scale(1.2); }
  }

  .ground-crack {
    position: absolute;
    bottom: 8%;
    left: 20%;
    width: 60%;
    height: 3px;
    background: #8B4513;
    animation: crack 2s ease-in-out infinite;
    transform-origin: center;
  }

  .crack2 {
    left: 30%;
    width: 40%;
    bottom: 6%;
    animation-delay: 1s;
    transform: rotate(15deg);
  }

  @keyframes crack {
    0%, 100% { opacity: 0.3; transform: scaleX(0.8); }
    50% { opacity: 0.8; transform: scaleX(1.1); }
  }

  .bass-wave {
    position: absolute;
    left: 50%;
    top: 55%;
    width: 60px;
    height: 60px;
    border: 3px solid #2d5a27;
    border-radius: 50%;
    transform: translate(-50%, -50%) scale(0);
    opacity: 0;
    animation: bassWave 2s ease-out infinite;
  }

  .bw2 { animation-delay: 0.6s; }
  .bw3 { animation-delay: 1.2s; }

  @keyframes bassWave {
    0% { transform: translate(-50%, -50%) scale(0); opacity: 0.6; }
    100% { transform: translate(-50%, -50%) scale(4); opacity: 0; }
  }

  .bass-guitar {
    animation: bassThump 1s ease-in-out infinite;
    transform-origin: 130px 200px;
  }

  @keyframes bassThump {
    0%, 100% { transform: rotate(0deg); }
    50% { transform: rotate(-2deg); }
  }

  .arm-right {
    animation: pluckBass 1s ease-in-out infinite;
    transform-origin: center top;
  }

  @keyframes pluckBass {
    0%, 100% { transform: translateX(0); }
    30% { transform: translateX(3px); }
    60% { transform: translateX(-2px); }
  }
</style>
