---
// Band heroes standing heroically with capes blowing in the wind
---

<div class="heroes-scene">
  <div class="heroes-bg">
    <div class="wind-lines">
      <div class="wind w1"></div>
      <div class="wind w2"></div>
      <div class="wind w3"></div>
      <div class="wind w4"></div>
      <div class="wind w5"></div>
      <div class="wind w6"></div>
    </div>
  </div>

  <div class="heroes-lineup">
    <div class="hero-figure hero-p">
      <img src="/p.png" alt="Mr P" class="hero-img" />
      <span class="hero-label">MR P</span>
    </div>
    <div class="hero-figure hero-dano">
      <img src="/dano.png" alt="Dano" class="hero-img" />
      <span class="hero-label">DANO</span>
    </div>
    <div class="hero-figure hero-darby">
      <img src="/darby.png" alt="Darby" class="hero-img" />
      <span class="hero-label">DARBY</span>
    </div>
  </div>
</div>

<style>
  .heroes-scene {
    position: relative;
    width: 100%;
    height: 200px;
    overflow: hidden;
    background: linear-gradient(180deg, #87CEEB 0%, #B0D4E8 40%, #f5a623 85%, #e8641b 100%);
    border-top: 4px solid var(--brown);
    border-bottom: 4px solid var(--brown);
  }

  .heroes-bg {
    position: absolute;
    inset: 0;
    overflow: hidden;
  }

  /* Wind lines blowing across */
  .wind-lines {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .wind {
    position: absolute;
    height: 2px;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.4), transparent);
    animation: windBlow 2s linear infinite;
  }

  .w1 { top: 20%; width: 120px; animation-delay: 0s; animation-duration: 1.8s; }
  .w2 { top: 35%; width: 80px; animation-delay: 0.4s; animation-duration: 2.2s; }
  .w3 { top: 50%; width: 150px; animation-delay: 0.8s; animation-duration: 1.6s; }
  .w4 { top: 30%; width: 60px; animation-delay: 1.2s; animation-duration: 2s; }
  .w5 { top: 45%; width: 100px; animation-delay: 0.2s; animation-duration: 2.4s; }
  .w6 { top: 60%; width: 90px; animation-delay: 0.6s; animation-duration: 1.9s; }

  @keyframes windBlow {
    0% { left: -150px; opacity: 0; }
    15% { opacity: 0.6; }
    85% { opacity: 0.6; }
    100% { left: 110%; opacity: 0; }
  }

  /* Heroes lineup */
  .heroes-lineup {
    position: absolute;
    bottom: 10px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    align-items: flex-end;
    gap: 1.5rem;
    z-index: 10;
  }

  .hero-figure {
    position: relative;
    text-align: center;
    animation: heroFloat 3s ease-in-out infinite;
  }

  .hero-figure:nth-child(1) { animation-delay: 0s; }
  .hero-figure:nth-child(2) { animation-delay: -1s; }
  .hero-figure:nth-child(3) { animation-delay: -2s; }

  @keyframes heroFloat {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-6px); }
  }

  .hero-img {
    height: 140px;
    width: auto;
    filter: drop-shadow(4px 4px 0 rgba(0,0,0,0.3));
    object-fit: contain;
  }

  .hero-label {
    display: block;
    font-family: var(--comic);
    font-size: 1.2rem;
    color: var(--cream);
    letter-spacing: 3px;
    text-shadow: 2px 2px 0 rgba(0,0,0,0.5);
    margin-top: 0.25rem;
  }

  @media (max-width: 768px) {
    .heroes-scene { height: 170px; }
    .hero-img { height: 110px; }
    .heroes-lineup { gap: 0.75rem; }
    .hero-label { font-size: 0.9rem; }
  }

  @media (max-width: 480px) {
    .heroes-scene { height: 140px; }
    .hero-img { height: 85px; }
    .heroes-lineup { gap: 0.5rem; }
    .hero-label { font-size: 0.75rem; }
  }
</style>
