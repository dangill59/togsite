---
// Dano - Guitar & Vocals - Suburban grandpa
// Superpower: The Dad Frequency - guitar tone so devastating it mows lawns and grills burgers at 50 yards
---

<div class="character dano">
  <div class="power-effects">
    <div class="lawn-line ll1"></div>
    <div class="lawn-line ll2"></div>
    <div class="lawn-line ll3"></div>
    <span class="floating-item fi1">&#127806;</span>
    <span class="floating-item fi2">&#128293;</span>
    <span class="floating-item fi3">&#127806;</span>
    <span class="floating-item fi4">&#9749;</span>
    <span class="floating-item fi5">&#127806;</span>
    <div class="sonic-ring sr1"></div>
    <div class="sonic-ring sr2"></div>
    <div class="sonic-ring sr3"></div>
  </div>
  <svg viewBox="0 0 300 400" class="char-svg">
    <!-- Ground shadow -->
    <ellipse cx="150" cy="385" rx="80" ry="12" fill="rgba(0,0,0,0.15)"/>

    <!-- Legs - khaki dad pants -->
    <rect x="110" y="285" width="30" height="90" rx="8" fill="#C2B280" class="leg-left"/>
    <rect x="160" y="285" width="30" height="90" rx="8" fill="#C2B280" class="leg-right"/>

    <!-- New Balance sneakers (the dad shoe) -->
    <rect x="100" y="365" width="48" height="20" rx="10" fill="#DCDCDC"/>
    <rect x="152" y="365" width="48" height="20" rx="10" fill="#DCDCDC"/>
    <text x="124" y="379" text-anchor="middle" font-size="7" fill="#999" font-weight="bold">NB</text>
    <text x="176" y="379" text-anchor="middle" font-size="7" fill="#999" font-weight="bold">NB</text>

    <!-- Body - dad polo tucked in -->
    <rect x="90" y="175" width="120" height="125" rx="18" fill="#4169E1"/>

    <!-- Polo collar -->
    <path d="M120,178 L150,195 L180,178" fill="none" stroke="#3155b0" stroke-width="4"/>
    <line x1="150" y1="195" x2="150" y2="215" stroke="#3155b0" stroke-width="2"/>
    <circle cx="150" cy="200" r="3" fill="white"/>
    <circle cx="150" cy="210" r="3" fill="white"/>

    <!-- Belt - braided leather, naturally -->
    <rect x="90" y="285" width="120" height="12" rx="3" fill="#5C4033"/>
    <rect x="138" y="282" width="24" height="18" rx="2" fill="#C0C0C0"/>

    <!-- Left arm - fretting -->
    <rect x="50" y="195" width="32" height="85" rx="11" fill="#FDBCB4" class="arm-left"/>
    <!-- Right arm - strumming -->
    <rect x="218" y="205" width="32" height="80" rx="11" fill="#FDBCB4" class="arm-right"/>

    <!-- Guitar -->
    <g class="guitar">
      <!-- Neck -->
      <rect x="35" y="120" width="10" height="170" rx="3" fill="#8B4513"/>
      <rect x="36" y="120" width="8" height="170" rx="2" fill="#A0522D"/>
      <!-- Frets -->
      <line x1="35" y1="140" x2="45" y2="140" stroke="#DAA520" stroke-width="1.5"/>
      <line x1="35" y1="160" x2="45" y2="160" stroke="#DAA520" stroke-width="1.5"/>
      <line x1="35" y1="180" x2="45" y2="180" stroke="#DAA520" stroke-width="1.5"/>
      <line x1="35" y1="200" x2="45" y2="200" stroke="#DAA520" stroke-width="1.5"/>
      <circle cx="40" cy="150" r="2" fill="#DAA520"/>
      <circle cx="40" cy="190" r="2" fill="#DAA520"/>
      <!-- Headstock -->
      <rect x="32" y="108" width="16" height="18" rx="4" fill="#5C3317"/>
      <circle cx="36" cy="112" r="2.5" fill="#C0C0C0"/>
      <circle cx="44" cy="112" r="2.5" fill="#C0C0C0"/>
      <circle cx="36" cy="120" r="2.5" fill="#C0C0C0"/>
      <circle cx="44" cy="120" r="2.5" fill="#C0C0C0"/>
      <!-- Body -->
      <path d="M195,230 Q240,230 245,265 Q248,300 220,310 Q200,315 180,310 Q152,300 155,265 Q158,230 195,230Z" fill="#f5a623"/>
      <path d="M195,235 Q235,235 238,265 Q240,295 215,305 Q200,308 185,305 Q160,295 162,265 Q165,235 195,235Z" fill="#DAA520"/>
      <circle cx="200" cy="270" r="18" fill="#5C3317"/>
      <circle cx="200" cy="270" r="14" fill="#1a1a1a"/>
      <!-- Strings -->
      <line x1="37" y1="126" x2="188" y2="255" stroke="#DAA520" stroke-width="1"/>
      <line x1="39" y1="126" x2="193" y2="260" stroke="#DAA520" stroke-width="1"/>
      <line x1="41" y1="126" x2="198" y2="265" stroke="#C0C0C0" stroke-width="0.8"/>
      <line x1="43" y1="126" x2="203" y2="270" stroke="#C0C0C0" stroke-width="0.8"/>
      <line x1="39" y1="126" x2="208" y2="275" stroke="#C0C0C0" stroke-width="0.6"/>
      <line x1="41" y1="126" x2="213" y2="280" stroke="#C0C0C0" stroke-width="0.6"/>
    </g>

    <!-- Neck -->
    <rect x="128" y="150" width="44" height="32" rx="10" fill="#FDBCB4"/>

    <!-- Head -->
    <ellipse cx="150" cy="110" rx="50" ry="55" fill="#FDBCB4"/>

    <!-- Glasses - classic grandpa wire frames -->
    <circle cx="130" cy="102" r="16" fill="none" stroke="#C0C0C0" stroke-width="2.5"/>
    <circle cx="170" cy="102" r="16" fill="none" stroke="#C0C0C0" stroke-width="2.5"/>
    <line x1="146" y1="102" x2="154" y2="102" stroke="#C0C0C0" stroke-width="2.5"/>
    <line x1="114" y1="102" x2="100" y2="97" stroke="#C0C0C0" stroke-width="2"/>
    <line x1="186" y1="102" x2="200" y2="97" stroke="#C0C0C0" stroke-width="2"/>

    <!-- Eyes behind glasses -->
    <ellipse cx="130" cy="102" rx="8" ry="7" fill="white"/>
    <ellipse cx="170" cy="102" rx="8" ry="7" fill="white"/>
    <circle cx="132" cy="102" r="4" fill="#6B4423"/>
    <circle cx="172" cy="102" r="4" fill="#6B4423"/>
    <circle cx="133" cy="101" r="2" fill="#1a1a1a"/>
    <circle cx="173" cy="101" r="2" fill="#1a1a1a"/>
    <circle cx="134" cy="100" r="1" fill="white"/>
    <circle cx="174" cy="100" r="1" fill="white"/>

    <!-- Eyebrows - slightly concerned grandpa look -->
    <path d="M117,90 Q130,85 143,91" stroke="#999" stroke-width="3" fill="none" stroke-linecap="round"/>
    <path d="M157,91 Q170,85 183,90" stroke="#999" stroke-width="3" fill="none" stroke-linecap="round"/>

    <!-- Goatee -->
    <path d="M140,130 Q150,155 160,130" fill="#999"/>
    <path d="M142,128 L142,140 Q150,148 158,140 L158,128" fill="#999"/>

    <!-- Smile - warm grandpa grin -->
    <path d="M132,125 Q150,140 168,125" stroke="#1a1a1a" stroke-width="2.5" fill="none" stroke-linecap="round"/>
    <path d="M136,126 Q150,135 164,126" fill="white"/>

    <!-- Nose -->
    <ellipse cx="150" cy="113" rx="7" ry="5" fill="#F0A090"/>

    <!-- Thinning grey hair -->
    <path d="M100,85 Q100,50 125,42 Q150,35 175,42 Q200,50 200,85" fill="#C0C0C0"/>
    <path d="M100,85 Q98,65 110,50" fill="#C0C0C0"/>
    <path d="M200,85 Q202,65 190,50" fill="#C0C0C0"/>

    <!-- Subtle smile lines -->
    <path d="M110,118 Q115,125 118,118" stroke="#E8A89C" stroke-width="1" fill="none"/>
    <path d="M182,118 Q185,125 190,118" stroke="#E8A89C" stroke-width="1" fill="none"/>

    <!-- Cargo shorts pocket detail -->
    <rect x="95" y="295" width="20" height="25" rx="3" fill="none" stroke="#a89860" stroke-width="1.5"/>
    <rect x="185" y="295" width="20" height="25" rx="3" fill="none" stroke="#a89860" stroke-width="1.5"/>
  </svg>
  <div class="char-name">DANO</div>
  <div class="char-power">The Dad Frequency</div>
  <div class="char-desc">Guitar tone so powerful it mows lawns and perfectly grills burgers within a 50-yard radius.</div>
</div>

<style>
  .dano {
    position: relative;
    text-align: center;
    max-width: 320px;
  }

  .char-svg {
    width: 100%;
    max-width: 280px;
    filter: drop-shadow(3px 3px 0 rgba(0,0,0,0.2));
    position: relative;
    z-index: 2;
  }

  .char-name {
    font-family: var(--comic);
    font-size: 2.2rem;
    color: var(--brown);
    letter-spacing: 4px;
    text-shadow: 2px 2px 0 rgba(0,0,0,0.15);
    margin-top: 0.25rem;
  }

  .char-power {
    font-family: var(--comic);
    font-size: 1rem;
    color: #4169E1;
    letter-spacing: 2px;
    text-transform: uppercase;
  }

  .char-desc {
    font-size: 0.9rem;
    opacity: 0.7;
    margin-top: 0.5rem;
    max-width: 260px;
    margin-left: auto;
    margin-right: auto;
  }

  .power-effects {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 3;
  }

  .floating-item {
    position: absolute;
    font-size: 1.5rem;
    animation: floatUp 4s ease-in-out infinite;
    opacity: 0;
  }

  .fi1 { left: 5%; top: 50%; animation-delay: 0s; }
  .fi2 { right: 5%; top: 35%; animation-delay: 0.8s; }
  .fi3 { left: 10%; top: 20%; animation-delay: 1.6s; }
  .fi4 { right: 12%; top: 55%; animation-delay: 2.4s; }
  .fi5 { right: 0%; top: 15%; animation-delay: 3.2s; }

  @keyframes floatUp {
    0% { opacity: 0; transform: translateY(10px) scale(0.5); }
    15% { opacity: 1; }
    85% { opacity: 1; }
    100% { opacity: 0; transform: translateY(-50px) scale(1.3) rotate(20deg); }
  }

  .lawn-line {
    position: absolute;
    bottom: 10%;
    height: 2px;
    background: repeating-linear-gradient(90deg, #2d8a27 0px, #2d8a27 8px, transparent 8px, transparent 12px);
    animation: mowLine 3s ease-in-out infinite;
    opacity: 0.5;
  }

  .ll1 { left: 10%; width: 80%; }
  .ll2 { left: 15%; width: 70%; bottom: 7%; animation-delay: 1s; }
  .ll3 { left: 20%; width: 60%; bottom: 4%; animation-delay: 2s; }

  @keyframes mowLine {
    0%, 100% { opacity: 0.2; transform: scaleX(0.7); }
    50% { opacity: 0.6; transform: scaleX(1); }
  }

  .sonic-ring {
    position: absolute;
    right: 10%;
    top: 45%;
    width: 40px;
    height: 40px;
    border: 2px solid #f5a623;
    border-radius: 50%;
    opacity: 0;
    animation: sonicPulse 2s ease-out infinite;
  }

  .sr2 { animation-delay: 0.6s; }
  .sr3 { animation-delay: 1.2s; }

  @keyframes sonicPulse {
    0% { transform: scale(0.5); opacity: 0.5; }
    100% { transform: scale(4); opacity: 0; }
  }

  .guitar {
    animation: guitarBob 0.8s ease-in-out infinite;
    transform-origin: 150px 230px;
  }

  @keyframes guitarBob {
    0%, 100% { transform: rotate(0deg); }
    50% { transform: rotate(1.5deg); }
  }

  .arm-right {
    animation: strumGuitar 0.8s ease-in-out infinite;
  }

  @keyframes strumGuitar {
    0%, 100% { transform: translateY(0); }
    25% { transform: translateY(4px); }
    75% { transform: translateY(-3px); }
  }
</style>
