---
import BaseLayout from '../layouts/BaseLayout.astro';
import ComicBurst from '../components/ComicBurst.astro';
import Cityscape from '../components/Cityscape.astro';
import SpeedLines from '../components/SpeedLines.astro';
---

<BaseLayout title="Music | Those One Guys">
  <section class="music-hero halftone">
    <SpeedLines color="#fdf5e6" opacity={0.1} />
    <Cityscape color="#1a0a05" opacity={0.25} />
    <div class="music-hero-inner">
      <div class="burst-row">
        <ComicBurst text="WHAM!" bg="#ff69b4" shape="bang" size="md" rotate={-14} />
        <ComicBurst text="THOSE!" bg="#e8641b" shape="star" size="sm" rotate={20} />
      </div>
      <h1 class="page-hero-title comic-title">Music</h1>
      <div class="burst-row">
        <ComicBurst text="ONE!" bg="#1a8a7d" shape="pow" size="sm" rotate={-10} />
        <ComicBurst text="KERPOW!" bg="#1e90ff" shape="star" size="md" rotate={8} />
      </div>
    </div>
  </section>

  <section class="section">
    <p class="section-subtitle">Crank it up. Here's what we've been cooking.</p>

    <div class="spotify-embed comic-panel">
      <div class="embed-header">
        <ComicBurst text="THOSE!" bg="#e8641b" shape="star" size="sm" rotate={-10} />
        <ComicBurst text="ONE!" bg="#1a8a7d" shape="pow" size="sm" rotate={8} />
        <ComicBurst text="GUYS!" bg="#6b2d5b" shape="jagged" size="sm" rotate={-5} />
      </div>
      <iframe
        style="border-radius: 4px;"
        src="https://open.spotify.com/embed/album/2HisOxjnnfc8p8lKSlLU9t?utm_source=generator&theme=0"
        width="100%"
        height="352"
        frameborder="0"
        allowfullscreen=""
        allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
        loading="lazy"
      ></iframe>
    </div>
  </section>

  <section class="streaming-section halftone">
    <Cityscape color="#1a0a05" opacity={0.2} />
    <SpeedLines color="#fdf5e6" opacity={0.06} />
    <div class="streaming-inner">
      <div class="streaming-bursts">
        <ComicBurst text="THOSE!" bg="#e8641b" shape="star" size="md" rotate={-8} float />
        <ComicBurst text="ONE!" bg="#1a8a7d" shape="pow" size="sm" rotate={15} float delay={200} />
      </div>
      <h2 class="comic-title">Find Us On</h2>
      <div class="streaming-links">
        <a href="https://open.spotify.com/album/2HisOxjnnfc8p8lKSlLU9t" target="_blank" rel="noopener" class="stream-badge">Spotify</a>
        <a href="#" class="stream-badge">Apple Music</a>
        <a href="#" class="stream-badge">YouTube</a>
        <a href="#" class="stream-badge">Bandcamp</a>
      </div>
      <div class="streaming-bursts">
        <ComicBurst text="GUYS!" bg="#6b2d5b" shape="jagged" size="sm" rotate={-12} float delay={300} />
        <ComicBurst text="ZAP!" bg="#ff69b4" shape="zap" size="md" rotate={10} float delay={100} />
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .music-hero {
    position: relative;
    background: linear-gradient(135deg, var(--orange), var(--plum));
    padding: 5rem 2rem;
    overflow: hidden;
    text-align: center;
  }

  .music-hero-inner {
    position: relative;
    z-index: 2;
  }

  .page-hero-title {
    font-size: clamp(3rem, 8vw, 5.5rem);
    color: var(--cream);
    text-shadow: 4px 4px 0 rgba(0,0,0,0.4);
  }

  .spotify-embed {
    max-width: 700px;
    margin: 0 auto;
    background: white;
    padding: 1.5rem;
  }

  .spotify-embed iframe {
    display: block;
  }

  .embed-header {
    display: flex;
    justify-content: center;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }

  .streaming-section {
    background: var(--brown);
    color: var(--cream);
    text-align: center;
    padding: 4rem 2rem;
    position: relative;
    overflow: hidden;
  }

  .streaming-inner {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }

  .streaming-section h2 {
    font-size: 2.5rem;
  }

  .streaming-bursts {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .streaming-links {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .stream-badge {
    display: inline-block;
    padding: 0.75rem 2rem;
    border: 3px solid var(--gold);
    border-radius: 4px;
    color: var(--gold);
    font-family: var(--comic);
    font-size: 1.2rem;
    letter-spacing: 3px;
    transition: background 0.3s, color 0.3s, transform 0.2s;
    box-shadow: 4px 4px 0 rgba(0,0,0,0.4);
  }

  .stream-badge:hover {
    background: var(--gold);
    color: var(--brown);
    transform: translate(-2px, -2px);
    box-shadow: 6px 6px 0 rgba(0,0,0,0.4);
  }
</style>
