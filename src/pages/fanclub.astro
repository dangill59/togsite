---
import BaseLayout from '../layouts/BaseLayout.astro';
import ComicBurst from '../components/ComicBurst.astro';
import Cityscape from '../components/Cityscape.astro';
import SpeedLines from '../components/SpeedLines.astro';
---

<BaseLayout title="Hero Squad | Those One Guys">
  <section class="fan-hero halftone">
    <SpeedLines color="#fdf5e6" opacity={0.1} />
    <Cityscape color="#1a0a05" opacity={0.25} />
    <div class="fan-hero-inner">
      <div class="burst-row">
        <ComicBurst text="JOIN!" bg="#e8251b" shape="bang" size="md" rotate={-12} />
        <ComicBurst text="THE!" bg="#ffe135" color="#5c3317" shape="pow" size="sm" rotate={18} />
      </div>
      <h1 class="page-hero-title comic-title">Hero Squad</h1>
      <div class="burst-row">
        <ComicBurst text="KERPOW!" bg="#e8641b" shape="star" size="md" rotate={-8} />
        <ComicBurst text="GUYS!" bg="#6b2d5b" shape="jagged" size="sm" rotate={10} />
      </div>
    </div>
  </section>

  <!-- SIGNUP -->
  <section class="section" id="signup-section">
    <div class="signup-intro">
      <h2 class="comic-title section-title">Become An Official Fan</h2>
      <p class="section-subtitle">Sign up, get your Hero Card, flash it at the show, and score surprise merch. It's that easy.</p>
      <div class="perks">
        <div class="perk comic-panel">
          <ComicBurst text="1" bg="#e8641b" shape="star" size="sm" rotate={-5} />
          <h3>Sign Up</h3>
          <p>Drop your name below and you're in the club.</p>
        </div>
        <div class="perk comic-panel">
          <ComicBurst text="2" bg="#1a8a7d" shape="pow" size="sm" rotate={8} />
          <h3>Get Your Card</h3>
          <p>Instant Hero Card with your own superhero character and signal code. Save it to your phone.</p>
        </div>
        <div class="perk comic-panel">
          <ComicBurst text="3" bg="#6b2d5b" shape="jagged" size="sm" rotate={-8} />
          <h3>Show It, Score It</h3>
          <p>Flash your card at any show for surprise merch and perks.</p>
        </div>
      </div>
    </div>

    <form class="signup-form comic-panel" id="fanForm">
      <div class="form-row">
        <div class="form-group">
          <label for="fanName">Your Name</label>
          <input type="text" id="fanName" name="name" placeholder="What do they call you?" required />
        </div>
        <div class="form-group">
          <label for="fanEmail">Email</label>
          <input type="email" id="fanEmail" name="email" placeholder="your@email.com" required />
        </div>
      </div>
      <div class="form-group">
        <label for="favMember">Favorite Member</label>
        <select id="favMember" name="favMember">
          <option value="all">Can't Pick - Love 'Em All</option>
          <option value="darby">Darby (Bass & Vocals)</option>
          <option value="dano">Dano (Guitar & Vocals)</option>
          <option value="p">P (Drums & Vocals)</option>
        </select>
      </div>
      <div class="form-group">
        <label for="superpower">Your Superpower</label>
        <select id="superpowerSelect">
          <option value="">Pick a power...</option>
          <option value="Super Strength">Super Strength</option>
          <option value="Lightning Speed">Lightning Speed</option>
          <option value="Mind Control">Mind Control</option>
          <option value="Fire Breathing">Fire Breathing</option>
          <option value="Laser Eyes">Laser Eyes</option>
          <option value="Sonic Scream">Sonic Scream</option>
          <option value="Time Travel">Time Travel</option>
          <option value="Teleportation">Teleportation</option>
          <option value="X-Ray Vision">X-Ray Vision</option>
          <option value="Invisibility">Invisibility</option>
          <option value="custom">Other - I'm Special</option>
        </select>
        <input type="text" id="superpowerCustom" name="superpower" placeholder="Type your superpower..." style="display:none; margin-top: 0.5rem;" />
      </div>
      <button type="submit" class="btn btn-primary">Get My Hero Card</button>
    </form>
  </section>

  <!-- FAN CARD (hidden until signup) -->
  <section class="section card-section" id="cardSection" style="display:none;">
    <div class="confirm-msg" id="confirmMsg">
      <h2 class="comic-title section-title confirm-title">You're In! Welcome, Hero!</h2>
      <p class="section-subtitle">Your submission has been sent. Check your email for confirmation. Screenshot your card below and flash it at any show!</p>
    </div>

    <div class="fan-card" id="fanCard">
      <div class="card-bg"></div>
      <div class="card-content">
        <div class="card-header">
          <div class="card-bursts-left">
            <ComicBurst text="THOSE!" bg="#e8641b" shape="star" size="xs" rotate={-10} />
          </div>
          <div class="card-title">
            <span class="card-label">OFFICIAL FAN CARD</span>
            <span class="card-band comic-title">THOSE ONE GUYS</span>
          </div>
          <div class="card-bursts-right">
            <ComicBurst text="GUYS!" bg="#6b2d5b" shape="pow" size="xs" rotate={10} />
          </div>
        </div>

        <div class="card-body">
          <div class="card-hero-row">
            <div class="card-avatar">
              <canvas id="heroCanvas" width="130" height="190"></canvas>
              <img id="heroImage" class="hero-image" style="display:none;" alt="Your Hero Character" />
              <div id="heroLoading" class="hero-loading" style="display:none;">
                <div class="hero-loading-spinner"></div>
                <span>Generating your hero...</span>
              </div>
            </div>
            <div class="card-info-col">
              <div class="card-member-info">
                <span class="card-field-label">HERO</span>
                <span class="card-name" id="cardName">---</span>
              </div>
              <div class="card-detail">
                <span class="card-field-label">SUPERPOWER</span>
                <span class="card-value card-power-text" id="cardPower">---</span>
              </div>
              <div class="card-details">
                <div class="card-detail">
                  <span class="card-field-label">SIGNAL CODE</span>
                  <span class="card-value" id="cardNumber">---</span>
                </div>
                <div class="card-detail">
                  <span class="card-field-label">SINCE</span>
                  <span class="card-value" id="cardDate">---</span>
                </div>
              </div>
              <div class="card-detail">
                <span class="card-field-label">ALLY</span>
                <span class="card-value" id="cardFav">---</span>
              </div>
            </div>
          </div>
        </div>

        <div class="card-footer">
          <div class="card-stamp">
            <ComicBurst text="VIP!" bg="#e8251b" shape="bang" size="sm" rotate={-5} />
          </div>
          <div class="card-qr" id="cardQR"></div>
          <div class="card-stamp">
            <ComicBurst text="FAN!" bg="#1a8a7d" shape="star" size="sm" rotate={8} />
          </div>
        </div>

        <div class="card-bottom-text">
          Flash this card at any Those One Guys show for surprise merch!
        </div>
      </div>
    </div>

    <div class="card-actions">
      <button class="btn btn-secondary" id="screenshotBtn">Save Screenshot</button>
      <button class="btn btn-secondary" id="editBtn">Edit Profile</button>
      <button class="btn btn-danger" id="deleteBtn">Delete Profile</button>
    </div>

    <div class="share-card comic-panel">
      <h3 class="comic-title">Spread The Word</h3>
      <p>Get your friends in the club. Share this QR code or link.</p>
      <div class="share-qr">
        <img src="/fanclub-qr.png" alt="Scan to join the Hero Squad" width="180" height="180" />
      </div>
      <div class="share-link-box">
        <input type="text" value="https://togsite.vercel.app/fanclub" readonly id="shareLink" />
        <button class="btn btn-primary" id="copyBtn">Copy</button>
      </div>
    </div>
  </section>

  <!-- SHARE QR (always visible, below signup too) -->
  <section class="section qr-section" id="qrAlwaysSection">
    <div class="qr-promo">
      <div class="burst-row">
        <ComicBurst text="SCAN!" bg="#e8641b" shape="star" size="md" rotate={-10} />
        <ComicBurst text="JOIN!" bg="#1a8a7d" shape="pow" size="md" rotate={8} />
      </div>
      <h2 class="comic-title section-title">Join The Hero Squad</h2>
      <p class="section-subtitle">Scan the code or share the link. Show your card at any show for surprise merch.</p>
      <div class="qr-big comic-panel">
        <img src="/fanclub-qr.png" alt="Scan to join Those One Guys Hero Squad" width="280" height="280" />
        <p class="qr-url">togsite.vercel.app/fanclub</p>
      </div>
      <div class="burst-row">
        <ComicBurst text="THOSE!" bg="#e8641b" shape="star" size="sm" rotate={-15} float />
        <ComicBurst text="ONE!" bg="#1a8a7d" shape="bang" size="sm" rotate={10} float delay={200} />
        <ComicBurst text="GUYS!" bg="#6b2d5b" shape="jagged" size="sm" rotate={-5} float delay={400} />
      </div>
    </div>
  </section>

  <script>
    // === HERO CHARACTER GENERATOR ===
    function seededRand(seed: number) {
      seed = (seed * 1103515245 + 12345) & 0x7fffffff;
      return { val: (seed % 1000) / 1000, seed };
    }

    function pickFrom(arr: string[], seed: number) {
      const r = seededRand(seed);
      return { val: arr[Math.floor(r.val * arr.length)], seed: r.seed };
    }

    const skinTones = ['#FDBCB4','#F0C8A0','#D2A06D','#8D5524','#6B4019','#3D2B1F'];
    const hairColors = ['#1a1a1a','#4A3728','#8B4513','#D2691E','#DAA520','#C0C0C0','#B7410E','#FF4500','#800080','#1E90FF'];
    const capeColors = ['#e8641b','#c0392b','#1a8a7d','#6b2d5b','#1E90FF','#ff69b4','#DAA520','#2d5a27'];
    const suitColors = ['#2c2c54','#1a1a3e','#4169E1','#2d5a27','#8B0000','#4a0080','#1a4a15','#333'];
    const maskShapes = ['domino','full','pointed','visor','none'];
    const hairStyles = ['spiky','flowing','mohawk','short','bald','wild','ponytail'];
    const powerIcons: Record<string, {symbol: string, color: string}> = {
      'Super Strength': { symbol: '💪', color: '#c0392b' },
      'Lightning Speed': { symbol: '⚡', color: '#f5a623' },
      'Mind Control': { symbol: '🧠', color: '#9b59b6' },
      'Fire Breathing': { symbol: '🔥', color: '#e8641b' },
      'Laser Eyes': { symbol: '👁', color: '#e8251b' },
      'Sonic Scream': { symbol: '🔊', color: '#1E90FF' },
      'Time Travel': { symbol: '⏰', color: '#1a8a7d' },
      'Teleportation': { symbol: '✨', color: '#6b2d5b' },
      'X-Ray Vision': { symbol: '🔍', color: '#2ecc71' },
      'Invisibility': { symbol: '👻', color: '#95a5a6' },
    };

    function drawHero(canvas: HTMLCanvasElement, seed: number, power: string) {
      const ctx = canvas.getContext('2d')!;
      const w = canvas.width, h = canvas.height;
      ctx.clearRect(0, 0, w, h);

      let s = seed;
      let r;

      // Pick traits from seed
      r = pickFrom(skinTones, s); const skin = r.val; s = r.seed;
      r = pickFrom(hairColors, s); const hair = r.val; s = r.seed;
      r = pickFrom(capeColors, s); const cape = r.val; s = r.seed;
      r = pickFrom(suitColors, s); const suit = r.val; s = r.seed;
      r = pickFrom(maskShapes, s); const mask = r.val; s = r.seed;
      r = pickFrom(hairStyles, s); const hairStyle = r.val; s = r.seed;
      r = seededRand(s); const bodyWidth = 28 + r.val * 16; s = r.seed;
      r = seededRand(s); const shoulderExtra = 4 + r.val * 10; s = r.seed;

      const cx = w / 2, legTop = 125, feetY = 178;

      // Cape
      ctx.fillStyle = cape;
      ctx.beginPath();
      ctx.moveTo(cx - bodyWidth/2 - 4, 68);
      ctx.quadraticCurveTo(cx - bodyWidth - 10, 140, cx - bodyWidth/2 - 15, feetY + 5);
      ctx.lineTo(cx + bodyWidth/2 + 15, feetY + 5);
      ctx.quadraticCurveTo(cx + bodyWidth + 10, 140, cx + bodyWidth/2 + 4, 68);
      ctx.closePath();
      ctx.fill();
      // Cape edge
      ctx.strokeStyle = 'rgba(0,0,0,0.2)';
      ctx.lineWidth = 1.5;
      ctx.stroke();

      // Legs
      ctx.fillStyle = suit;
      ctx.fillRect(cx - 14, legTop, 11, 55);
      ctx.fillRect(cx + 3, legTop, 11, 55);

      // Boots
      r = seededRand(s); s = r.seed;
      const bootColor = r.val > 0.5 ? cape : '#1a1a1a';
      ctx.fillStyle = bootColor;
      ctx.beginPath(); ctx.roundRect(cx - 17, feetY - 4, 16, 12, 4); ctx.fill();
      ctx.beginPath(); ctx.roundRect(cx + 1, feetY - 4, 16, 12, 4); ctx.fill();

      // Body
      ctx.fillStyle = suit;
      ctx.beginPath();
      ctx.roundRect(cx - bodyWidth/2, 65, bodyWidth, 65, 8);
      ctx.fill();

      // Shoulders
      ctx.beginPath();
      ctx.roundRect(cx - bodyWidth/2 - shoulderExtra/2, 63, bodyWidth + shoulderExtra, 16, 6);
      ctx.fill();

      // Belt
      ctx.fillStyle = cape;
      ctx.fillRect(cx - bodyWidth/2, legTop - 5, bodyWidth, 7);
      // Belt buckle
      ctx.fillStyle = '#DAA520';
      ctx.beginPath(); ctx.roundRect(cx - 6, legTop - 7, 12, 11, 2); ctx.fill();
      ctx.fillStyle = suit;
      ctx.font = 'bold 7px sans-serif';
      ctx.textAlign = 'center';
      ctx.fillText('T', cx, legTop + 2);

      // Chest emblem
      const pi = powerIcons[power];
      if (pi) {
        ctx.fillStyle = pi.color;
        ctx.beginPath();
        ctx.moveTo(cx, 72); ctx.lineTo(cx + 14, 82); ctx.lineTo(cx + 10, 100);
        ctx.lineTo(cx, 105); ctx.lineTo(cx - 10, 100); ctx.lineTo(cx - 14, 82);
        ctx.closePath(); ctx.fill();
        ctx.strokeStyle = '#DAA520'; ctx.lineWidth = 1.5; ctx.stroke();
        ctx.font = '14px sans-serif'; ctx.textAlign = 'center';
        ctx.fillText(pi.symbol, cx, 95);
      } else {
        // Custom power - star emblem
        ctx.fillStyle = '#DAA520';
        ctx.beginPath();
        ctx.moveTo(cx, 74); ctx.lineTo(cx + 12, 82); ctx.lineTo(cx + 8, 98);
        ctx.lineTo(cx, 102); ctx.lineTo(cx - 8, 98); ctx.lineTo(cx - 12, 82);
        ctx.closePath(); ctx.fill();
        ctx.fillStyle = suit;
        ctx.font = 'bold 11px sans-serif';
        ctx.fillText('★', cx, 94);
      }

      // Arms
      ctx.fillStyle = skin;
      // Left arm
      ctx.save(); ctx.translate(cx - bodyWidth/2 - 2, 70); ctx.rotate(-0.2);
      ctx.beginPath(); ctx.roundRect(-5, 0, 12, 45, 5); ctx.fill();
      // Fist
      ctx.fillRect(-6, 42, 14, 10); ctx.beginPath(); ctx.roundRect(-6, 42, 14, 10, 4); ctx.fill();
      ctx.restore();
      // Right arm
      ctx.save(); ctx.translate(cx + bodyWidth/2 + 2, 70); ctx.rotate(0.2);
      ctx.beginPath(); ctx.roundRect(-7, 0, 12, 45, 5); ctx.fill();
      ctx.fillRect(-7, 42, 14, 10); ctx.beginPath(); ctx.roundRect(-7, 42, 14, 10, 4); ctx.fill();
      ctx.restore();

      // Gloves
      ctx.fillStyle = cape;
      ctx.save(); ctx.translate(cx - bodyWidth/2 - 2, 70); ctx.rotate(-0.2);
      ctx.beginPath(); ctx.roundRect(-6, 38, 15, 16, 4); ctx.fill();
      ctx.restore();
      ctx.save(); ctx.translate(cx + bodyWidth/2 + 2, 70); ctx.rotate(0.2);
      ctx.beginPath(); ctx.roundRect(-8, 38, 15, 16, 4); ctx.fill();
      ctx.restore();

      // Neck
      ctx.fillStyle = skin;
      ctx.fillRect(cx - 7, 50, 14, 18);

      // Head
      ctx.fillStyle = skin;
      ctx.beginPath(); ctx.ellipse(cx, 35, 20, 22, 0, 0, Math.PI * 2); ctx.fill();

      // Hair
      ctx.fillStyle = hair;
      if (hairStyle === 'spiky') {
        for (let i = -3; i <= 3; i++) {
          ctx.beginPath();
          ctx.moveTo(cx + i * 6 - 3, 22);
          ctx.lineTo(cx + i * 6 + 3, 22);
          ctx.lineTo(cx + i * 6, 5 - Math.abs(i) * 2);
          ctx.fill();
        }
        ctx.beginPath(); ctx.ellipse(cx, 22, 20, 10, 0, Math.PI, Math.PI * 2); ctx.fill();
      } else if (hairStyle === 'flowing') {
        ctx.beginPath(); ctx.ellipse(cx, 22, 22, 14, 0, Math.PI, Math.PI * 2); ctx.fill();
        ctx.beginPath(); ctx.moveTo(cx + 20, 25); ctx.quadraticCurveTo(cx + 30, 50, cx + 22, 65); ctx.lineTo(cx + 18, 60); ctx.quadraticCurveTo(cx + 24, 45, cx + 18, 25); ctx.fill();
        ctx.beginPath(); ctx.moveTo(cx - 20, 25); ctx.quadraticCurveTo(cx - 30, 50, cx - 22, 65); ctx.lineTo(cx - 18, 60); ctx.quadraticCurveTo(cx - 24, 45, cx - 18, 25); ctx.fill();
      } else if (hairStyle === 'mohawk') {
        ctx.beginPath(); ctx.moveTo(cx - 5, 22); ctx.lineTo(cx + 5, 22); ctx.lineTo(cx + 3, 0); ctx.lineTo(cx - 3, 0); ctx.fill();
        ctx.fillRect(cx - 4, 15, 8, 10);
      } else if (hairStyle === 'short') {
        ctx.beginPath(); ctx.ellipse(cx, 22, 21, 13, 0, Math.PI, Math.PI * 2); ctx.fill();
      } else if (hairStyle === 'wild') {
        ctx.beginPath(); ctx.ellipse(cx, 25, 26, 20, 0, Math.PI, Math.PI * 2); ctx.fill();
        for (let i = 0; i < 5; i++) {
          const angle = Math.PI + (i / 4) * Math.PI;
          ctx.beginPath();
          ctx.moveTo(cx + Math.cos(angle) * 20, 25 + Math.sin(angle) * 16);
          ctx.lineTo(cx + Math.cos(angle) * 30, 25 + Math.sin(angle) * 24);
          ctx.lineTo(cx + Math.cos(angle + 0.3) * 18, 25 + Math.sin(angle + 0.3) * 14);
          ctx.fill();
        }
      } else if (hairStyle === 'ponytail') {
        ctx.beginPath(); ctx.ellipse(cx, 22, 21, 12, 0, Math.PI, Math.PI * 2); ctx.fill();
        ctx.beginPath(); ctx.moveTo(cx - 18, 28); ctx.quadraticCurveTo(cx - 28, 45, cx - 20, 70); ctx.lineTo(cx - 16, 68); ctx.quadraticCurveTo(cx - 22, 42, cx - 16, 28); ctx.fill();
      }
      // bald = no hair drawn

      // Mask
      if (mask === 'domino') {
        ctx.fillStyle = suit;
        ctx.beginPath(); ctx.ellipse(cx - 8, 33, 10, 6, -0.1, 0, Math.PI * 2); ctx.fill();
        ctx.beginPath(); ctx.ellipse(cx + 8, 33, 10, 6, 0.1, 0, Math.PI * 2); ctx.fill();
        // Eye whites
        ctx.fillStyle = 'white';
        ctx.beginPath(); ctx.ellipse(cx - 8, 33, 5, 4, 0, 0, Math.PI * 2); ctx.fill();
        ctx.beginPath(); ctx.ellipse(cx + 8, 33, 5, 4, 0, 0, Math.PI * 2); ctx.fill();
        ctx.fillStyle = '#1a1a1a';
        ctx.beginPath(); ctx.arc(cx - 7, 33, 2, 0, Math.PI * 2); ctx.fill();
        ctx.beginPath(); ctx.arc(cx + 9, 33, 2, 0, Math.PI * 2); ctx.fill();
      } else if (mask === 'full') {
        ctx.fillStyle = suit;
        ctx.beginPath(); ctx.ellipse(cx, 30, 20, 16, 0, Math.PI, Math.PI * 2); ctx.fill();
        ctx.fillStyle = 'white';
        ctx.beginPath(); ctx.ellipse(cx - 8, 33, 6, 4, -0.15, 0, Math.PI * 2); ctx.fill();
        ctx.beginPath(); ctx.ellipse(cx + 8, 33, 6, 4, 0.15, 0, Math.PI * 2); ctx.fill();
      } else if (mask === 'pointed') {
        ctx.fillStyle = suit;
        ctx.beginPath(); ctx.ellipse(cx, 30, 20, 14, 0, Math.PI, Math.PI * 2); ctx.fill();
        ctx.beginPath(); ctx.moveTo(cx - 18, 22); ctx.lineTo(cx - 24, 6); ctx.lineTo(cx - 12, 18); ctx.fill();
        ctx.beginPath(); ctx.moveTo(cx + 18, 22); ctx.lineTo(cx + 24, 6); ctx.lineTo(cx + 12, 18); ctx.fill();
        ctx.fillStyle = 'white';
        ctx.beginPath(); ctx.ellipse(cx - 8, 33, 6, 4, -0.15, 0, Math.PI * 2); ctx.fill();
        ctx.beginPath(); ctx.ellipse(cx + 8, 33, 6, 4, 0.15, 0, Math.PI * 2); ctx.fill();
      } else if (mask === 'visor') {
        ctx.fillStyle = suit;
        ctx.beginPath(); ctx.roundRect(cx - 20, 28, 40, 12, 6); ctx.fill();
        ctx.fillStyle = cape;
        ctx.globalAlpha = 0.6;
        ctx.beginPath(); ctx.roundRect(cx - 18, 30, 36, 8, 4); ctx.fill();
        ctx.globalAlpha = 1;
      } else {
        // No mask - regular eyes
        ctx.fillStyle = 'white';
        ctx.beginPath(); ctx.ellipse(cx - 8, 33, 5, 4, 0, 0, Math.PI * 2); ctx.fill();
        ctx.beginPath(); ctx.ellipse(cx + 8, 33, 5, 4, 0, 0, Math.PI * 2); ctx.fill();
        ctx.fillStyle = '#1a1a1a';
        ctx.beginPath(); ctx.arc(cx - 7, 33, 2.5, 0, Math.PI * 2); ctx.fill();
        ctx.beginPath(); ctx.arc(cx + 9, 33, 2.5, 0, Math.PI * 2); ctx.fill();
      }

      // Mouth - determined grin
      ctx.strokeStyle = skin === '#FDBCB4' || skin === '#F0C8A0' ? '#a0705a' : '#1a1a1a';
      ctx.lineWidth = 1.5;
      ctx.beginPath();
      ctx.moveTo(cx - 7, 44);
      ctx.quadraticCurveTo(cx, 50, cx + 7, 44);
      ctx.stroke();

      // Power glow effect
      const glowColor = pi ? pi.color : '#DAA520';
      ctx.shadowColor = glowColor;
      ctx.shadowBlur = 15;
      ctx.fillStyle = 'transparent';
      ctx.fillRect(0, 0, 0, 0);
      ctx.shadowBlur = 0;
    }

    // === SUPABASE (via REST API, no SDK needed) ===
    const SUPABASE_URL = 'https://ysookbcxirqdogezjboo.supabase.co';
    const SUPABASE_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Inlzb29rYmN4aXJxZG9nZXpqYm9vIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzUwNzAzMDUsImV4cCI6MjA5MDY0NjMwNX0._UNYB0wR74hlzTpfHuo34SDixc_Cj5E9qTku9TMG0Uw';
    const hdrs = { 'apikey': SUPABASE_KEY, 'Authorization': `Bearer ${SUPABASE_KEY}`, 'Content-Type': 'application/json', 'Prefer': 'return=representation' };

    const db = {
      async select(email: string) {
        const res = await fetch(`${SUPABASE_URL}/rest/v1/fans?email=eq.${encodeURIComponent(email)}&limit=1`, { headers: hdrs });
        const data = await res.json();
        return data?.[0] || null;
      },
      async insert(fan: any) {
        const res = await fetch(`${SUPABASE_URL}/rest/v1/fans`, { method: 'POST', headers: hdrs, body: JSON.stringify(fan) });
        return res;
      },
      async update(email: string, fields: any) {
        await fetch(`${SUPABASE_URL}/rest/v1/fans?email=eq.${encodeURIComponent(email)}`, { method: 'PATCH', headers: hdrs, body: JSON.stringify(fields) });
      },
      async remove(email: string) {
        await fetch(`${SUPABASE_URL}/rest/v1/fans?email=eq.${encodeURIComponent(email)}`, { method: 'DELETE', headers: hdrs });
      },
    };

    // === FORM LOGIC ===
    const form = document.getElementById('fanForm');
    const signupSection = document.getElementById('signup-section');
    const cardSection = document.getElementById('cardSection');
    const superpowerSelect = document.getElementById('superpowerSelect') as HTMLSelectElement;
    const superpowerCustom = document.getElementById('superpowerCustom') as HTMLInputElement;

    superpowerSelect?.addEventListener('change', () => {
      superpowerCustom.style.display = superpowerSelect.value === 'custom' ? 'block' : 'none';
      if (superpowerSelect.value !== 'custom') superpowerCustom.value = '';
    });

    function getSuperpower(): string {
      if (superpowerSelect?.value === 'custom') return superpowerCustom?.value.trim() || 'Mystery Power';
      return superpowerSelect?.value || 'Mystery Power';
    }

    function makeHash(name: string, email: string): number {
      return Array.from(name + email).reduce((acc, c) => ((acc << 5) - acc + c.charCodeAt(0)) | 0, 0);
    }

    function makeSignalCode(hash: number): string {
      return 'TOG-' + Math.abs(hash).toString(36).toUpperCase().slice(0, 6);
    }

    function fillCard(name: string, signalCode: string, dateStr: string, favText: string, power: string, hash: number) {
      document.getElementById('cardName')!.textContent = name.toUpperCase();
      document.getElementById('cardNumber')!.textContent = signalCode;
      document.getElementById('cardDate')!.textContent = dateStr;
      document.getElementById('cardFav')!.textContent = favText;
      document.getElementById('cardPower')!.textContent = power;

      const canvas = document.getElementById('heroCanvas') as HTMLCanvasElement;
      if (canvas) drawHero(canvas, Math.abs(hash), power);

      const qrEl = document.getElementById('cardQR')!;
      qrEl.innerHTML = '';
      const qrCanvas = document.createElement('canvas');
      qrCanvas.width = 80; qrCanvas.height = 80;
      const ctx = qrCanvas.getContext('2d')!;
      ctx.fillStyle = '#1a1a1a'; ctx.fillRect(0, 0, 80, 80);
      let seed = Math.abs(hash);
      for (let y = 0; y < 10; y++) {
        for (let x = 0; x < 10; x++) {
          seed = (seed * 1103515245 + 12345) & 0x7fffffff;
          if (seed % 3 !== 0) { ctx.fillStyle = '#fdf5e6'; ctx.fillRect(x * 8, y * 8, 7, 7); }
        }
      }
      ctx.fillStyle = '#e8641b';
      ctx.fillRect(0, 0, 16, 16); ctx.fillRect(64, 0, 16, 16); ctx.fillRect(0, 64, 16, 16);
      ctx.fillStyle = '#1a1a1a';
      ctx.fillRect(3, 3, 10, 10); ctx.fillRect(67, 3, 10, 10); ctx.fillRect(3, 67, 10, 10);
      ctx.fillStyle = '#e8641b';
      ctx.fillRect(5, 5, 6, 6); ctx.fillRect(69, 5, 6, 6); ctx.fillRect(5, 69, 6, 6);
      qrEl.appendChild(qrCanvas);
    }

    function showCard(name: string, email: string, favText: string, power: string, signalCode: string, dateStr: string, heroImg?: string) {
      const hash = makeHash(name, email);
      fillCard(name, signalCode, dateStr, favText, power, hash);
      const storageData: any = { name, email, signalCode, dateStr, favText, power };
      if (heroImg) storageData.heroImage = heroImg;
      localStorage.setItem('tog-fan', JSON.stringify(storageData));
      signupSection!.style.display = 'none';
      cardSection!.style.display = 'block';

      // Show AI image if available
      const heroImage = document.getElementById('heroImage') as HTMLImageElement;
      const heroCanvas = document.getElementById('heroCanvas') as HTMLCanvasElement;
      if (heroImg) {
        heroImage.src = heroImg;
        heroImage.style.display = 'block';
        heroCanvas.style.display = 'none';
      } else {
        heroImage.style.display = 'none';
        heroCanvas.style.display = 'block';
      }
    }

    async function generateHeroImage(name: string, superpower: string, favoriteMember: string): Promise<string | null> {
      const heroLoading = document.getElementById('heroLoading')!;
      const heroCanvas = document.getElementById('heroCanvas') as HTMLCanvasElement;
      heroLoading.style.display = 'flex';
      heroCanvas.style.display = 'none';

      try {
        const res = await fetch('/api/generate-hero', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ name, superpower, favoriteMember }),
        });
        const data = await res.json();
        heroLoading.style.display = 'none';
        if (data.image) return data.image;
        console.error('Hero generation failed:', data.error);
        return null;
      } catch (err) {
        heroLoading.style.display = 'none';
        console.error('Hero generation error:', err);
        return null;
      }
    }

    // === SIGNUP ===
    form?.addEventListener('submit', async (e) => {
      e.preventDefault();

      const name = (document.getElementById('fanName') as HTMLInputElement).value.trim();
      const email = (document.getElementById('fanEmail') as HTMLInputElement).value.trim();
      const fav = (document.getElementById('favMember') as HTMLSelectElement);
      const favText = fav.options[fav.selectedIndex].text;
      const power = getSuperpower();

      const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
      submitBtn.textContent = 'Sending...';
      submitBtn.disabled = true;

      const hash = makeHash(name, email);
      const signalCode = makeSignalCode(hash);
      const now = new Date();
      const dateStr = now.toLocaleDateString('en-US', { month: 'short', year: 'numeric' });

      // Check if fan exists (editing)
      const existing = await db.select(email);

      if (existing) {
        await db.update(email, { name, favorite_member: favText, superpower: power, signal_code: signalCode });
      } else {
        const res = await db.insert({ name, email, favorite_member: favText, superpower: power, signal_code: signalCode });
        if (!res.ok) {
          // Duplicate email - treat as update
          await db.update(email, { name, favorite_member: favText, superpower: power, signal_code: signalCode });
        }
      }

      // Also send to Formspree for email notification
      try {
        await fetch('https://formspree.io/f/xpqolkgy', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ name, email, favoriteMember: favText, superpower: power, signalCode, type: 'fan-club-signup' }),
        });
      } catch (err) {}

      // Show card immediately with canvas fallback, then generate AI hero
      showCard(name, email, favText, power, signalCode, dateStr);
      cardSection!.scrollIntoView({ behavior: 'smooth' });

      // Generate AI hero image in background
      const heroImg = await generateHeroImage(name, power, favText);
      if (heroImg) {
        showCard(name, email, favText, power, signalCode, dateStr, heroImg);
      }

      submitBtn.textContent = 'Get My Hero Card';
      submitBtn.disabled = false;
    });

    // === CHECK IF ALREADY SIGNED UP (localStorage first, then verify with DB) ===
    const saved = localStorage.getItem('tog-fan');
    if (saved) {
      try {
        const data = JSON.parse(saved);

        // Try to load from DB to get latest data
        const dbFan = await db.select(data.email);

        if (dbFan) {
          const hash = makeHash(dbFan.name, dbFan.email);
          const dateStr = new Date(dbFan.created_at).toLocaleDateString('en-US', { month: 'short', year: 'numeric' });
          showCard(dbFan.name, dbFan.email, dbFan.favorite_member, dbFan.superpower || 'Mystery Power', dbFan.signal_code, dateStr, data.heroImage || undefined);
        } else {
          // DB record gone but localStorage exists - show from local
          const hash = makeHash(data.name, data.email);
          fillCard(data.name, data.signalCode || data.memberNum, data.dateStr, data.favText, data.power || 'Mystery Power', hash);
          signupSection!.style.display = 'none';
          cardSection!.style.display = 'block';
          // Show saved AI image if available
          const heroImage = document.getElementById('heroImage') as HTMLImageElement;
          const heroCanvas = document.getElementById('heroCanvas') as HTMLCanvasElement;
          if (data.heroImage) {
            heroImage.src = data.heroImage;
            heroImage.style.display = 'block';
            heroCanvas.style.display = 'none';
          }
        }
      } catch(e) {}
    }

    // === SCREENSHOT ===
    document.getElementById('screenshotBtn')?.addEventListener('click', () => {
      alert('Take a screenshot of your Hero Card! On iPhone: Side + Volume Up. On Android: Power + Volume Down.');
    });

    // === EDIT PROFILE ===
    document.getElementById('editBtn')?.addEventListener('click', () => {
      const saved = localStorage.getItem('tog-fan');
      if (saved) {
        try {
          const data = JSON.parse(saved);
          (document.getElementById('fanName') as HTMLInputElement).value = data.name || '';
          (document.getElementById('fanEmail') as HTMLInputElement).value = data.email || '';
          const favSelect = document.getElementById('favMember') as HTMLSelectElement;
          for (let i = 0; i < favSelect.options.length; i++) {
            if (favSelect.options[i].text === data.favText) { favSelect.selectedIndex = i; break; }
          }
          const powerSelect = document.getElementById('superpowerSelect') as HTMLSelectElement;
          const customInput = document.getElementById('superpowerCustom') as HTMLInputElement;
          let found = false;
          for (let i = 0; i < powerSelect.options.length; i++) {
            if (powerSelect.options[i].value === data.power) { powerSelect.selectedIndex = i; found = true; break; }
          }
          if (!found && data.power) {
            powerSelect.value = 'custom';
            customInput.value = data.power;
            customInput.style.display = 'block';
          }
        } catch(e) {}
      }
      cardSection!.style.display = 'none';
      signupSection!.style.display = 'block';
      signupSection!.scrollIntoView({ behavior: 'smooth' });
    });

    // === DELETE PROFILE ===
    document.getElementById('deleteBtn')?.addEventListener('click', async () => {
      if (confirm('Are you sure you want to delete your fan profile? This cannot be undone.')) {
        const saved = localStorage.getItem('tog-fan');
        if (saved) {
          try {
            const data = JSON.parse(saved);
            await db.remove(data.email);
          } catch(e) {}
        }
        localStorage.removeItem('tog-fan');
        cardSection!.style.display = 'none';
        signupSection!.style.display = 'block';
        (document.getElementById('fanForm') as HTMLFormElement).reset();
        (document.getElementById('superpowerCustom') as HTMLInputElement).style.display = 'none';
        signupSection!.scrollIntoView({ behavior: 'smooth' });
      }
    });

    // === COPY LINK ===
    document.getElementById('copyBtn')?.addEventListener('click', () => {
      const input = document.getElementById('shareLink') as HTMLInputElement;
      navigator.clipboard.writeText(input.value).then(() => {
        const btn = document.getElementById('copyBtn')!;
        btn.textContent = 'Copied!';
        setTimeout(() => { btn.textContent = 'Copy'; }, 2000);
      });
    });
  </script>
</BaseLayout>

