---
import BaseLayout from '../layouts/BaseLayout.astro';
import ComicBurst from '../components/ComicBurst.astro';
import Cityscape from '../components/Cityscape.astro';
import SpeedLines from '../components/SpeedLines.astro';

const products = [
  { name: "TOG Tee", image: "/merch-black-t-shirt.png", price: "$25", desc: "Black tee with the growing THOSE ONE GUYS! and comic bursts." },
  { name: "TOG Mug", image: "/merch-coffee-mug.png", price: "$15", desc: "Start your morning loud. Coffee tastes better with comic book energy." },
  { name: "Enamel Pin", image: "/merch-enamel-pin.png", price: "$10", desc: "Slap it on your jacket, your bag, your soul. Collectible enamel pin." },
  { name: "TOG Cap", image: "/merch-baseball-cap.png", price: "$20", desc: "Trucker cap with the retro starburst logo. Dad approved." },
  { name: "Wristband", image: "/merch-sweatband-wristband.png", price: "$8", desc: "Rock hard. Sweat harder. Wristband for the committed fan." },
  { name: "Headband", image: "/merch-headband.png", price: "$10", desc: "TOG headband. Keep the sweat out and the groove in." },
  { name: "Bandana", image: "/merch-bandana.png", price: "$12", desc: "Comic burst bandana. Wear it, wave it, hang it on the wall." },
  { name: "Squad Pin", image: "/merch-squad-pin.png", price: "$10", desc: "TOG Squad enamel pin. Prove you're in the squad." },
  { name: "Squad Headband", image: "/merch-squad-headband.png", price: "$12", desc: "TOG Squad headband. Retro 70s vibes with the brown and orange stripes." },
  { name: "Squad Bandana", image: "/merch-squad-bandana.png", price: "$12", desc: "TOG Squad bandana. Rep the squad at every show." },
];
---

<BaseLayout title="Merch | Those One Guys">
  <section class="merch-hero halftone">
    <SpeedLines color="#fdf5e6" opacity={0.1} />
    <Cityscape color="#1a0a05" opacity={0.25} />
    <div class="merch-hero-inner">
      <div class="burst-row">
        <ComicBurst text="GRAB!" bg="#e8251b" shape="bang" size="md" rotate={-12} />
        <ComicBurst text="THOSE!" bg="#e8641b" shape="star" size="sm" rotate={18} />
      </div>
      <h1 class="page-hero-title comic-title">Merch</h1>
      <div class="burst-row">
        <ComicBurst text="GUYS!" bg="#6b2d5b" shape="pow" size="sm" rotate={-8} />
        <ComicBurst text="KERPOW!" bg="#1e90ff" shape="star" size="md" rotate={10} />
      </div>
    </div>
  </section>

  <section class="section">
    <p class="section-subtitle">Wear the noise. Rep the squad. Look incredibly cool doing it.</p>

    <div class="merch-grid">
      {products.map((product, i) => (
        <div class="merch-card comic-panel">
          <div class="merch-burst">
            <ComicBurst
              text={["BAM!", "POW!", "WHAM!", "CRASH!", "KERPOW!", "ZAP!", "BOOM!", "SMASH!", "YEAH!", "WHAP!"][i]}
              bg={["#e8251b", "#ffe135", "#1e90ff", "#ff69b4", "#c0392b", "#1a8a7d", "#f5a623", "#6b2d5b", "#e8641b", "#1e90ff"][i]}
              color={[1, 6].includes(i) ? "#5c3317" : "#fdf5e6"}
              shape={["bang", "pow", "star", "jagged", "star", "zap", "pow", "bang", "star", "jagged"] [i] as "bang" | "pow" | "star" | "jagged" | "zap"}
              size="sm"
              rotate={[-10, 12, -8, 15, -12, 10, -15, 8, -10, 14][i]}
            />
          </div>
          <div class="merch-img-wrap">
            <img src={product.image} alt={product.name} class="merch-img" />
          </div>
          <h3 class="merch-name">{product.name}</h3>
          <p class="merch-price">{product.price}</p>
          <p class="merch-desc">{product.desc}</p>
          <span class="merch-badge">Coming Soon</span>
        </div>
      ))}
    </div>

    <!-- Custom Hero Merch Section -->
    <div class="custom-hero-section" id="customHeroSection">
      <div class="custom-hero-header">
        <ComicBurst text="YOUR!" bg="#e8251b" shape="bang" size="md" rotate={-10} />
        <h2 class="comic-title section-title">Custom Hero Merch</h2>
        <ComicBurst text="HERO!" bg="#1a8a7d" shape="star" size="md" rotate={12} />
      </div>
      <p class="section-subtitle">TOG Squad members — put YOUR superhero on a tee, mug, or pin. Your hero, your merch.</p>

      <div id="customNotMember" class="custom-not-member">
        <p>You need a Hero Card to create custom merch.</p>
        <a href="/fanclub" class="btn btn-primary">Join TOG Hero Squad</a>
      </div>

      <div id="customBuilder" class="custom-builder" style="display:none;">
        <div class="custom-product-select">
          <h3 class="comic-title">Pick Your Product</h3>
          <div class="custom-product-options">
            <button class="custom-product-btn active" data-product="tee">
              <img src="/merch-black-t-shirt.png" alt="Tee" />
              <span>Tee — $30</span>
            </button>
            <button class="custom-product-btn" data-product="mug">
              <img src="/merch-coffee-mug.png" alt="Mug" />
              <span>Mug — $18</span>
            </button>
            <button class="custom-product-btn" data-product="pin">
              <img src="/merch-enamel-pin.png" alt="Pin" />
              <span>Pin — $12</span>
            </button>
            <button class="custom-product-btn" data-product="cap">
              <img src="/merch-baseball-cap.png" alt="Cap" />
              <span>Cap — $25</span>
            </button>
          </div>
        </div>

        <div class="custom-mockup comic-panel" id="customMockup">
          <div class="mockup-loading" id="mockupLoading" style="display:none;">
            <div class="mockup-spinner"></div>
            <span>Generating your custom mockup...</span>
          </div>
          <img id="mockupImage" class="mockup-image" style="display:none;" alt="Your Custom Merch" />
          <p class="mockup-label" id="mockupLabel">Click a product to generate your custom preview</p>
        </div>

        <div class="mockup-variations" id="mockupVariations" style="display:none;">
          <button class="var-btn active" data-var="0">1</button>
          <button class="var-btn" data-var="1">2</button>
          <button class="var-btn" data-var="2">3</button>
        </div>

        <div class="custom-btn-row">
          <button class="btn btn-secondary" id="saveMockupBtn" style="display:none;">Save Mockup</button>
          <button class="btn btn-secondary" id="newVariationBtn" style="display:none;">New Variation</button>
          <button class="btn btn-primary custom-order-btn" id="customOrderBtn">
            Request Custom Order — Coming Soon
          </button>
        </div>
        <p class="mockup-slots" id="mockupSlots" style="display:none;"></p>
      </div>
    </div>

    <div class="merch-cta">
      <ComicBurst text="THOSE!" bg="#e8641b" shape="star" size="md" rotate={-10} float />
      <div class="merch-cta-text">
        <h2 class="comic-title">Want First Dibs?</h2>
        <p>TOG Hero Squad members get early access and exclusive merch drops. Join the squad.</p>
        <a href="/fanclub" class="btn btn-primary">Join TOG Hero Squad</a>
      </div>
      <ComicBurst text="GUYS!" bg="#6b2d5b" shape="pow" size="md" rotate={8} float delay={200} />
    </div>
  </section>
</BaseLayout>

<script>
  let heroImageSrc: string | null = null;
  let heroName: string = '';
  let fanEmail: string = '';
  let currentProduct: string = '';
  let currentVar: number = 0;
  const MAX_VARS = 3;

  // In-memory cache, loaded from Supabase on init
  const mockupCache: Record<string, string[]> = {};

  function getSavedMockups(): Record<string, string[]> {
    return mockupCache;
  }

  // Load saved mockups from Supabase
  async function loadMockupsFromDB() {
    if (!fanEmail) return;
    try {
      const res = await fetch(`/api/generate-mockup?email=${encodeURIComponent(fanEmail)}`);
      const data = await res.json();
      for (const [product, urls] of Object.entries(data)) {
        if (Array.isArray(urls)) mockupCache[product] = urls as string[];
      }
      updateProductBadges();
    } catch (e) {
      console.warn('Could not load saved mockups:', e);
    }
  }

  function getProductMockups(product: string): string[] {
    return getSavedMockups()[product] || [];
  }

  function updateUI() {
    const variations = getProductMockups(currentProduct);
    const varBar = document.getElementById('mockupVariations')!;
    const newVarBtn = document.getElementById('newVariationBtn')!;
    const slotsText = document.getElementById('mockupSlots')!;
    const saveBtn = document.getElementById('saveMockupBtn')!;

    if (variations.length > 0) {
      // Show variation buttons
      varBar.style.display = 'flex';
      document.querySelectorAll('.var-btn').forEach((btn, i) => {
        const b = btn as HTMLElement;
        if (i < variations.length) {
          b.classList.remove('empty');
          b.classList.toggle('active', i === currentVar);
        } else {
          b.classList.add('empty');
          b.classList.remove('active');
        }
      });

      saveBtn.style.display = '';

      // Show "New Variation" if under limit
      if (variations.length < MAX_VARS) {
        newVarBtn.style.display = '';
        slotsText.style.display = 'block';
        slotsText.textContent = `${variations.length} of ${MAX_VARS} variations used`;
      } else {
        newVarBtn.style.display = 'none';
        slotsText.style.display = 'block';
        slotsText.textContent = `All ${MAX_VARS} variations used`;
      }
    } else {
      varBar.style.display = 'none';
      newVarBtn.style.display = 'none';
      saveBtn.style.display = 'none';
      slotsText.style.display = 'none';
    }

    updateProductBadges();
  }

  function updateProductBadges() {
    const mockups = getSavedMockups();
    document.querySelectorAll('.custom-product-btn').forEach(btn => {
      const product = (btn as HTMLElement).dataset.product!;
      let badge = btn.querySelector('.product-badge') as HTMLElement;
      const count = (mockups[product] || []).length;
      if (count > 0) {
        if (!badge) {
          badge = document.createElement('span');
          badge.className = 'product-badge';
          btn.appendChild(badge);
        }
        badge.textContent = String(count);
      } else if (badge) {
        badge.remove();
      }
    });
  }

  function showMockup(product: string, varIndex: number) {
    const variations = getProductMockups(product);
    if (varIndex >= variations.length) return;

    const mockupImg = document.getElementById('mockupImage') as HTMLImageElement;
    const label = document.getElementById('mockupLabel')!;
    const loading = document.getElementById('mockupLoading')!;

    loading.style.display = 'none';
    mockupImg.src = variations[varIndex];
    mockupImg.style.display = 'block';
    currentProduct = product;
    currentVar = varIndex;

    const productName = product.charAt(0).toUpperCase() + product.slice(1);
    label.textContent = `${heroName.toUpperCase()}'s Custom ${productName} — Version ${varIndex + 1}`;

    updateUI();
  }

  // Compress hero image to reduce upload size on mobile
  let compressedHero: string | null = null;
  function getCompressedHero(): Promise<string> {
    if (compressedHero) return Promise.resolve(compressedHero);
    return new Promise((resolve) => {
      const img = new Image();
      img.onload = () => {
        const c = document.createElement('canvas');
        const maxSize = 512;
        let w = img.width, h = img.height;
        if (w > h) { if (w > maxSize) { h = h * maxSize / w; w = maxSize; } }
        else { if (h > maxSize) { w = w * maxSize / h; h = maxSize; } }
        c.width = w; c.height = h;
        c.getContext('2d')!.drawImage(img, 0, 0, w, h);
        compressedHero = c.toDataURL('image/jpeg', 0.8);
        resolve(compressedHero);
      };
      img.src = heroImageSrc!;
    });
  }

  async function generateNewMockup(product: string) {
    const variations = getProductMockups(product);
    if (variations.length >= MAX_VARS) return;

    const mockupImg = document.getElementById('mockupImage') as HTMLImageElement;
    const loading = document.getElementById('mockupLoading')!;
    const label = document.getElementById('mockupLabel')!;
    const loadingText = loading.querySelector('span')!;

    loading.style.display = 'flex';
    mockupImg.style.display = 'none';
    loadingText.textContent = 'Preparing image...';
    label.textContent = `Generating variation ${variations.length + 1} of ${MAX_VARS}...`;

    try {
      const hero = await getCompressedHero();

      let seconds = 0;
      const timer = setInterval(() => {
        seconds++;
        loadingText.textContent = `Generating... ${seconds}s (usually takes 20-40s)`;
      }, 1000);

      const res = await fetch('/api/generate-mockup', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ heroImage: hero, product, heroName, email: fanEmail }),
      });
      clearInterval(timer);
      const data = await res.json();

      if (data.image) {
        if (!mockupCache[product]) mockupCache[product] = [];
        mockupCache[product].push(data.image);
        currentProduct = product;
        currentVar = mockupCache[product].length - 1;
        showMockup(product, currentVar);
      } else {
        loading.style.display = 'none';
        label.textContent = `Failed: ${data.error || 'Unknown error'} — try again`;
      }
    } catch (err: any) {
      loading.style.display = 'none';
      label.textContent = `Failed: ${err.message || 'Network error'} — try again`;
      console.error('Mockup error:', err);
    }
  }

  async function handleProductClick(product: string) {
    currentProduct = product;
    const variations = getProductMockups(product);

    if (variations.length > 0) {
      // Show first variation
      showMockup(product, 0);
    } else {
      // Generate first mockup
      await generateNewMockup(product);
    }
  }

  // Check if user is a TOG Squad member
  const saved = localStorage.getItem('tog-fan');
  const notMember = document.getElementById('customNotMember')!;
  const builder = document.getElementById('customBuilder')!;

  if (saved) {
    try {
      const data = JSON.parse(saved);
      if (data.heroImage) {
        notMember.style.display = 'none';
        builder.style.display = 'block';
        heroImageSrc = data.heroImage;
        heroName = data.name || 'Hero';
        fanEmail = data.email || '';
        // Load saved mockups from Supabase
        loadMockupsFromDB();
      }
    } catch (e) {}
  }

  // Product selection
  document.querySelectorAll('.custom-product-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.custom-product-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      handleProductClick((btn as HTMLElement).dataset.product!);
    });
  });

  // Variation toggle
  document.querySelectorAll('.var-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const idx = parseInt((btn as HTMLElement).dataset.var!);
      const variations = getProductMockups(currentProduct);
      if (idx < variations.length) {
        showMockup(currentProduct, idx);
      }
    });
  });

  // New variation
  document.getElementById('newVariationBtn')?.addEventListener('click', () => {
    generateNewMockup(currentProduct);
  });

  // Save mockup download
  document.getElementById('saveMockupBtn')?.addEventListener('click', () => {
    const mockupImg = document.getElementById('mockupImage') as HTMLImageElement;
    if (mockupImg && mockupImg.src) {
      const link = document.createElement('a');
      link.download = `tog-custom-${currentProduct}-v${currentVar + 1}.png`;
      link.href = mockupImg.src;
      link.click();
    }
  });

  // Coming soon button
  document.getElementById('customOrderBtn')?.addEventListener('click', () => {
    alert('Custom hero merch is coming soon! We\u2019ll notify TOG Squad members when it launches.');
  });
</script>

<style>
  .merch-hero {
    position: relative;
    background: linear-gradient(135deg, var(--brown), var(--orange), var(--plum));
    padding: 5rem 2rem;
    overflow: hidden;
    text-align: center;
  }

  .merch-hero-inner {
    position: relative;
    z-index: 2;
  }

  .page-hero-title {
    font-size: clamp(3rem, 8vw, 5.5rem);
    color: var(--cream);
    text-shadow: 4px 4px 0 rgba(0,0,0,0.4);
  }

  .merch-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 2rem;
    margin-bottom: 4rem;
  }

  .merch-card {
    background: white;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    position: relative;
    transition: transform 0.2s;
  }

  .merch-card:hover {
    transform: translateY(-4px);
  }

  .merch-burst {
    position: absolute;
    top: -15px;
    right: -10px;
    z-index: 5;
  }

  .merch-img-wrap {
    width: 100%;
    aspect-ratio: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    border-radius: 4px;
    margin-bottom: 1rem;
  }

  .merch-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 4px;
  }

  .merch-name {
    font-family: var(--comic);
    font-size: 1.4rem;
    color: var(--brown);
    letter-spacing: 2px;
  }

  .merch-price {
    font-family: var(--comic);
    font-size: 1.2rem;
    color: var(--orange);
    letter-spacing: 2px;
    margin: 0.25rem 0;
  }

  .merch-desc {
    font-size: 0.85rem;
    opacity: 0.7;
    margin-bottom: 1rem;
    max-width: 250px;
  }

  .merch-badge {
    font-family: var(--comic);
    font-size: 0.8rem;
    background: var(--brown);
    color: var(--gold);
    padding: 0.3rem 1rem;
    border-radius: 4px;
    letter-spacing: 2px;
    text-transform: uppercase;
  }

  /* === Custom Hero Merch === */
  .custom-hero-section {
    margin-bottom: 4rem;
    padding: 2rem;
    background: linear-gradient(135deg, rgba(92,51,23,0.05), rgba(232,100,27,0.08));
    border: 4px solid var(--brown);
    border-radius: 4px;
    box-shadow: 6px 6px 0 var(--brown);
  }

  .custom-hero-header {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 0.5rem;
  }

  .custom-not-member {
    text-align: center;
    padding: 2rem;
  }

  .custom-builder {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
  }

  .custom-product-select {
    text-align: center;
    margin-bottom: 1.5rem;
  }

  .custom-product-select h3 {
    color: var(--brown);
    font-size: 1.2rem;
    margin-bottom: 0.75rem;
  }

  .custom-product-options {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .custom-product-btn {
    position: relative;
    background: white;
    border: 3px solid var(--brown);
    border-radius: 4px;
    padding: 0.5rem;
    cursor: pointer;
    transition: all 0.2s;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
    width: 100px;
  }

  .custom-product-btn img {
    width: 70px;
    height: 70px;
    object-fit: cover;
    border-radius: 4px;
  }

  .custom-product-btn span {
    font-family: var(--comic);
    font-size: 0.7rem;
    color: var(--brown);
    letter-spacing: 1px;
  }

  .custom-product-btn:hover {
    transform: translateY(-2px);
    box-shadow: 3px 3px 0 var(--brown);
  }

  .custom-product-btn.active {
    border-color: var(--orange);
    box-shadow: 4px 4px 0 var(--orange);
    background: var(--cream);
  }

  .custom-mockup {
    text-align: center;
    padding: 1.5rem;
    background: white;
    max-width: 520px;
    width: 100%;
    margin: 0 auto;
    min-height: 300px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }

  .mockup-image {
    width: 100%;
    max-width: 480px;
    border-radius: 8px;
  }

  .mockup-loading {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    padding: 3rem;
    color: var(--brown);
    font-family: var(--comic);
    letter-spacing: 2px;
    font-size: 0.85rem;
  }

  .mockup-spinner {
    width: 50px;
    height: 50px;
    border: 4px solid rgba(92,51,23,0.2);
    border-top-color: var(--orange);
    border-radius: 50%;
    animation: mockupSpin 0.8s linear infinite;
  }

  @keyframes mockupSpin {
    to { transform: rotate(360deg); }
  }

  .mockup-label {
    font-family: var(--comic);
    font-size: 0.9rem;
    color: var(--brown);
    letter-spacing: 2px;
    margin-top: 0.75rem;
    opacity: 0.6;
  }

  .custom-btn-row {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .custom-order-btn {
    font-size: 1.1rem;
    padding: 1rem 2rem;
  }

  .mockup-variations {
    display: flex;
    gap: 0.5rem;
    justify-content: center;
    margin-bottom: 1rem;
  }

  .var-btn {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: 3px solid var(--brown);
    background: white;
    font-family: var(--comic);
    font-size: 0.9rem;
    color: var(--brown);
    cursor: pointer;
    transition: all 0.2s;
  }

  .var-btn.active {
    background: var(--orange);
    color: white;
    border-color: var(--orange);
    box-shadow: 2px 2px 0 var(--brown);
  }

  .var-btn.empty {
    opacity: 0.3;
    cursor: default;
    border-style: dashed;
  }

  .mockup-slots {
    font-family: var(--comic);
    font-size: 0.7rem;
    letter-spacing: 1px;
    color: var(--brown);
    opacity: 0.5;
    text-align: center;
    margin-top: 0.5rem;
  }

  .product-badge {
    position: absolute;
    top: -6px;
    right: -6px;
    background: #1a8a7d;
    color: white;
    width: 20px;
    height: 20px;
    border-radius: 50%;
    font-size: 0.7rem;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: bold;
  }

  .merch-cta {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 2rem;
    padding: 3rem 2rem;
    background: linear-gradient(135deg, var(--brown), var(--plum));
    border: 4px solid var(--brown);
    border-radius: 4px;
    box-shadow: 6px 6px 0 var(--brown);
    text-align: center;
    flex-wrap: wrap;
  }

  .merch-cta-text {
    max-width: 400px;
  }

  .merch-cta h2 {
    color: var(--gold);
    font-size: 2rem;
    margin-bottom: 0.5rem;
  }

  .merch-cta p {
    color: var(--cream);
    margin-bottom: 1.5rem;
    opacity: 0.9;
  }
</style>
