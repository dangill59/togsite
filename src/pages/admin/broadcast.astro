---
export const prerender = false;
import BaseLayout from '../../layouts/BaseLayout.astro';
import { shows, showSlug, showLabel } from '../../lib/shows';
const NAME_TOKEN = '{{name}}';
const BODY_PLACEHOLDER = `Hey ${NAME_TOKEN},\n\nWe're playing The Bourbon this Friday at 9pm. Doors at 8.\n\nBring the squad.\n\n— TOG`;

// Build show options for the post-show preset dropdown
const showOptions = shows.map((s) => ({
  id: showSlug(s),
  label: showLabel(s),
  venue: s.venue,
  date: s.date,
}));
---

<BaseLayout title="Broadcast | Admin">
  <section class="admin">
    <h1 class="comic-title">Broadcast to Squad</h1>

    <!-- Password gate -->
    <div id="gate" class="card">
      <h2>Admin password</h2>
      <input id="password" type="password" placeholder="Enter admin password" autocomplete="current-password" />
      <button id="unlockBtn" class="btn btn-primary">Unlock</button>
      <p id="gateError" class="error"></p>
    </div>

    <!-- Composer -->
    <div id="composer" style="display:none;">
      <div class="card">
        <div class="stats" id="stats">Loading...</div>
      </div>

      <div class="card">
        <h3>Templates</h3>
        <p class="template-help">Pick one to pre-fill the subject and body. You can edit before sending.</p>
        <div class="templates">
          <div class="template-row">
            <label>Post-show</label>
            <select id="postShowSelect">
              <option value="">— pick a show —</option>
              {showOptions.map((s) => (
                <option value={s.id} data-label={s.label} data-venue={s.venue} data-date={s.date}>{s.label}</option>
              ))}
            </select>
            <button id="postShowFill" class="btn btn-secondary" type="button">Use template</button>
          </div>
          <div class="template-row">
            <label>Upcoming-show heads-up</label>
            <select id="upcomingSelect">
              <option value="">— pick a show —</option>
              {showOptions.map((s) => (
                <option value={s.id} data-label={s.label} data-venue={s.venue} data-date={s.date}>{s.label}</option>
              ))}
            </select>
            <button id="upcomingFill" class="btn btn-secondary" type="button">Use template</button>
          </div>
        </div>
      </div>

      <div class="card">
        <label>Subject</label>
        <input id="subject" type="text" placeholder="The Bourbon, Friday — be there" />

        <label>Body (HTML allowed; <code set:html="&#123;&#123;name&#125;&#125;"></code> gets replaced with their first name)</label>
        <textarea id="body" rows="12" placeholder={BODY_PLACEHOLDER}></textarea>

        <div class="actions">
          <input id="testEmail" type="email" placeholder="Test send to (your email)" />
          <button id="testBtn" class="btn btn-secondary">Send test</button>
          <button id="dryBtn" class="btn">Preview count</button>
          <button id="sendBtn" class="btn btn-primary">Send to all</button>
        </div>
        <p id="status" class="status"></p>
      </div>

      <div class="card">
        <h3>Subscribed fans</h3>
        <ul id="fanList"></ul>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .admin {
    max-width: 800px;
    margin: 2rem auto;
    padding: 0 1.5rem;
  }
  .comic-title {
    color: var(--brown);
    text-align: center;
    margin-bottom: 2rem;
    font-size: 2.5rem;
  }
  .card {
    background: #fff;
    border: 3px solid var(--brown);
    box-shadow: 4px 4px 0 var(--brown);
    border-radius: 4px;
    padding: 1.5rem;
    margin-bottom: 1.5rem;
  }
  .card h2, .card h3 {
    margin-top: 0;
    color: var(--brown);
  }
  label {
    display: block;
    font-weight: 600;
    margin: 1rem 0 0.5rem;
    color: var(--brown);
    font-size: 0.95rem;
  }
  input, textarea {
    width: 100%;
    padding: 0.75rem;
    font: inherit;
    border: 2px solid var(--brown);
    border-radius: 4px;
    background: #fff;
    color: var(--brown);
  }
  textarea {
    font-family: ui-monospace, Menlo, monospace;
    font-size: 0.92rem;
    resize: vertical;
  }
  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 1rem;
    align-items: center;
  }
  .actions input {
    flex: 1;
    min-width: 200px;
  }
  .btn {
    padding: 0.7rem 1.4rem;
    font-family: var(--comic);
    font-size: 1rem;
    border: 3px solid var(--brown);
    border-radius: 4px;
    background: var(--cream);
    color: var(--brown);
    cursor: pointer;
    box-shadow: 3px 3px 0 var(--brown);
    text-transform: uppercase;
    letter-spacing: 1.5px;
  }
  .btn:hover { transform: translate(-1px, -1px); box-shadow: 4px 4px 0 var(--brown); }
  .btn:active { transform: translate(2px, 2px); box-shadow: 1px 1px 0 var(--brown); }
  .btn-primary { background: var(--orange); color: var(--cream); }
  .btn-secondary { background: var(--teal); color: var(--cream); }
  .stats {
    font-family: var(--comic);
    font-size: 1.3rem;
    color: var(--brown);
    text-align: center;
    letter-spacing: 1px;
  }
  .stats strong { color: var(--orange); font-size: 1.6rem; }
  .status, .error { margin-top: 1rem; font-weight: 600; }
  .error { color: var(--rust); }
  ul { padding-left: 1.5rem; }
  ul li { margin-bottom: 0.4rem; font-size: 0.92rem; }

  .template-help {
    margin: -0.5rem 0 0.75rem;
    font-size: 0.9rem;
    opacity: 0.7;
  }
  .templates {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .template-row {
    display: grid;
    grid-template-columns: minmax(180px, 1fr) 2fr auto;
    gap: 0.5rem;
    align-items: center;
  }
  .template-row label {
    margin: 0;
    font-size: 0.95rem;
  }
  .template-row select {
    width: 100%;
    padding: 0.6rem 0.75rem;
    border: 2px solid var(--brown);
    border-radius: 4px;
    background: #fff;
    color: var(--brown);
    font: inherit;
  }
  .template-row .btn {
    padding: 0.5rem 1rem;
    font-size: 0.9rem;
  }
  @media (max-width: 600px) {
    .template-row {
      grid-template-columns: 1fr;
    }
  }
  code {
    background: var(--cream);
    padding: 2px 6px;
    border-radius: 3px;
    font-family: ui-monospace, monospace;
    font-size: 0.85rem;
  }
</style>

<script>
  const $ = (id: string) => document.getElementById(id)!;
  const PW_KEY = 'tog-admin-pw';

  async function callApi(path: string, body: any, password: string) {
    const res = await fetch(path, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'x-admin-password': password },
      body: JSON.stringify(body),
    });
    const data = await res.json().catch(() => ({}));
    return { ok: res.ok, status: res.status, data };
  }

  async function loadStats(password: string) {
    const r = await callApi('/api/admin/list-fans', {}, password);
    if (!r.ok) return false;
    const subscribed = r.data.subscribed || [];
    $('stats').innerHTML = `
      <strong>${r.data.subscribedCount}</strong> subscribed &middot;
      <strong>${r.data.unsubscribedCount}</strong> unsubscribed
    `;
    const list = $('fanList');
    list.innerHTML = '';
    for (const f of subscribed) {
      const li = document.createElement('li');
      li.textContent = `${f.name || 'unnamed'} <${f.email}>${f.favorite_member ? ' — ' + f.favorite_member : ''}`;
      list.appendChild(li);
    }
    return true;
  }

  async function unlock() {
    const password = ($('password') as HTMLInputElement).value.trim();
    if (!password) return;
    const ok = await loadStats(password);
    if (ok) {
      sessionStorage.setItem(PW_KEY, password);
      $('gate').style.display = 'none';
      $('composer').style.display = 'block';
    } else {
      $('gateError').textContent = 'Wrong password.';
    }
  }

  $('unlockBtn').addEventListener('click', unlock);
  ($('password') as HTMLInputElement).addEventListener('keydown', (e) => {
    if (e.key === 'Enter') unlock();
  });

  // Auto-unlock if we have a saved password
  const saved = sessionStorage.getItem(PW_KEY);
  if (saved) {
    loadStats(saved).then((ok) => {
      if (ok) {
        $('gate').style.display = 'none';
        $('composer').style.display = 'block';
      } else {
        sessionStorage.removeItem(PW_KEY);
      }
    });
  }

  function getCreds() {
    return sessionStorage.getItem(PW_KEY) || ($('password') as HTMLInputElement).value.trim();
  }

  function getMessage() {
    return {
      subject: ($('subject') as HTMLInputElement).value.trim(),
      body: ($('body') as HTMLTextAreaElement).value.trim(),
    };
  }

  // === Templates ===
  function fillForm(subject: string, body: string) {
    ($('subject') as HTMLInputElement).value = subject;
    ($('body') as HTMLTextAreaElement).value = body;
    $('subject').scrollIntoView({ behavior: 'smooth', block: 'start' });
  }

  function selectedShow(selectId: string): { id: string; label: string; venue: string; date: string } | null {
    const sel = $(selectId) as HTMLSelectElement;
    if (!sel.value) return null;
    const opt = sel.options[sel.selectedIndex];
    return {
      id: sel.value,
      label: opt.dataset.label || sel.value,
      venue: opt.dataset.venue || '',
      date: opt.dataset.date || '',
    };
  }

  $('postShowFill').addEventListener('click', () => {
    const show = selectedShow('postShowSelect');
    if (!show) {
      $('status').textContent = 'Pick a show first.';
      return;
    }
    const subject = `Thanks for coming to ${show.venue}!`;
    const threadUrl = `https://thoseoneguys.band/shows#${show.id}`;
    const body = [
      `Hey {{name}},`,
      ``,
      `Thanks for coming out to <strong>${show.venue}</strong> last night. The energy in the room was unreal — we appreciate every one of you who showed up.`,
      ``,
      `Drop a comment on the show thread and tell us your favorite moment (or which song almost blew the speakers):`,
      ``,
      `<a href="${threadUrl}" style="display:inline-block;background:#e8641b;color:#fdf5e6;font-family:Impact,'Arial Black',sans-serif;font-size:18px;letter-spacing:3px;text-transform:uppercase;padding:12px 28px;border:3px solid #5c3317;box-shadow:4px 4px 0 #5c3317;text-decoration:none;">Open Squad Chatter</a>`,
      ``,
      `Bring your hero card to the next gig — we hook up squad members at the merch table.`,
      ``,
      `See you out there.`,
      `— Dano, Darby & Mr P`,
    ].join('\n');
    fillForm(subject, body);
  });

  $('upcomingFill').addEventListener('click', () => {
    const show = selectedShow('upcomingSelect');
    if (!show) {
      $('status').textContent = 'Pick a show first.';
      return;
    }
    const subject = `${show.venue} on ${show.date} — be there`;
    const threadUrl = `https://thoseoneguys.band/shows#${show.id}`;
    const body = [
      `Hey {{name}},`,
      ``,
      `Heads-up — we're playing <strong>${show.venue}</strong> on <strong>${show.date}</strong>. Bring the squad, bring your hero card, and come say hi at the merch table for some free swag.`,
      ``,
      `<a href="${threadUrl}" style="display:inline-block;background:#1a8a7d;color:#fdf5e6;font-family:Impact,'Arial Black',sans-serif;font-size:18px;letter-spacing:3px;text-transform:uppercase;padding:12px 28px;border:3px solid #5c3317;box-shadow:4px 4px 0 #5c3317;text-decoration:none;">Show Details + Directions</a>`,
      ``,
      `Loud guitars. Big grooves. Zero chill.`,
      `— TOG`,
    ].join('\n');
    fillForm(subject, body);
  });

  $('testBtn').addEventListener('click', async () => {
    const { subject, body } = getMessage();
    const testTo = ($('testEmail') as HTMLInputElement).value.trim();
    if (!subject || !body) return ($('status').textContent = 'Subject and body are required.');
    if (!testTo) return ($('status').textContent = 'Add a test email first.');
    $('status').textContent = 'Sending test...';
    const r = await callApi('/api/admin/broadcast', { subject, body, testTo }, getCreds());
    $('status').textContent = r.ok ? `Test sent to ${testTo}.` : `Failed: ${r.data.error || 'unknown error'}`;
  });

  $('dryBtn').addEventListener('click', async () => {
    const { subject, body } = getMessage();
    if (!subject || !body) return ($('status').textContent = 'Subject and body are required.');
    const r = await callApi('/api/admin/broadcast', { subject, body, dryRun: true }, getCreds());
    $('status').textContent = r.ok ? `Would send to ${r.data.recipients} fan(s).` : `Failed: ${r.data.error || 'unknown error'}`;
  });

  $('sendBtn').addEventListener('click', async () => {
    const { subject, body } = getMessage();
    if (!subject || !body) return ($('status').textContent = 'Subject and body are required.');
    const dry = await callApi('/api/admin/broadcast', { subject, body, dryRun: true }, getCreds());
    if (!dry.ok) return ($('status').textContent = `Failed: ${dry.data.error || 'unknown error'}`);
    if (!confirm(`Really send to ${dry.data.recipients} fan(s)? This is real.`)) return;
    $('status').textContent = `Sending to ${dry.data.recipients}...`;
    const r = await callApi('/api/admin/broadcast', { subject, body }, getCreds());
    if (r.ok) {
      $('status').textContent = `Sent: ${r.data.sent} / ${r.data.total}. Failed: ${r.data.failed}.`;
    } else {
      $('status').textContent = `Failed: ${r.data.error || 'unknown error'}`;
    }
  });
</script>
