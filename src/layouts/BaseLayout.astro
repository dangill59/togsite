---
interface Props {
  title?: string;
  description?: string;
}

const { title = "Those One Guys", description = "Those One Guys - Rock & Roll with a 70's groove" } = Astro.props;
const currentPath = Astro.url.pathname;

const navLinks = [
  { href: "/", label: "Home" },
  { href: "/about", label: "About" },
  { href: "/music", label: "Music" },
  { href: "/tunes", label: "Tunes" },
  { href: "/shows", label: "Shows" },
  { href: "/contact", label: "Contact" },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bangers&family=Righteous&family=Outfit:wght@300;400;600&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body>
    <nav class="nav">
      <a href="/" class="nav-logo">Those One Guys</a>
      <button class="nav-toggle" aria-label="Toggle menu" id="navToggle">
        <span></span><span></span><span></span>
      </button>
      <ul class="nav-links" id="navLinks">
        {navLinks.map((link) => (
          <li>
            <a href={link.href} class:list={[{ active: currentPath === link.href }]}>
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <main>
      <slot />
    </main>

    <footer class="footer">
      <div class="footer-inner">
        <p class="footer-logo">Those One Guys</p>
        <p class="footer-copy">&copy; {new Date().getFullYear()} Those One Guys. Keep it groovy.</p>
      </div>
    </footer>

    <script>
      const toggle = document.getElementById("navToggle");
      const links = document.getElementById("navLinks");
      toggle?.addEventListener("click", () => {
        links?.classList.toggle("open");
        toggle.classList.toggle("open");
      });
    </script>
  </body>
</html>

<style is:global>
  /* === Reset === */
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --orange: #e8641b;
    --gold: #f5a623;
    --brown: #5c3317;
    --cream: #fdf5e6;
    --teal: #1a8a7d;
    --plum: #6b2d5b;
    --rust: #c0392b;
    --comic: 'Bangers', cursive;
    --font-display: 'Righteous', cursive;
    --font-body: 'Outfit', sans-serif;
    --blue: #1e90ff;
    --red: #e8251b;
    --yellow: #ffe135;
    --pink: #ff69b4;
  }

  html { scroll-behavior: smooth; }

  body {
    font-family: var(--font-body);
    background: var(--cream);
    color: var(--brown);
    line-height: 1.6;
    min-height: 100vh;
  }

  h1, h2, h3, h4 {
    font-family: var(--font-display);
    line-height: 1.2;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  img { max-width: 100%; display: block; }

  /* === Nav === */
  .nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 2rem;
    background: var(--brown);
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .nav-logo {
    font-family: var(--comic);
    font-size: 1.8rem;
    color: var(--gold);
    letter-spacing: 3px;
    text-shadow: 2px 2px 0 rgba(0,0,0,0.3);
  }

  .nav-links {
    display: flex;
    list-style: none;
    gap: 2rem;
  }

  .nav-links a {
    color: var(--cream);
    font-weight: 600;
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    position: relative;
    transition: color 0.3s;
  }

  .nav-links a::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 0;
    height: 3px;
    background: var(--orange);
    border-radius: 2px;
    transition: width 0.3s;
  }

  .nav-links a:hover,
  .nav-links a.active {
    color: var(--gold);
  }

  .nav-links a:hover::after,
  .nav-links a.active::after {
    width: 100%;
  }

  .nav-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
  }

  .nav-toggle span {
    display: block;
    width: 28px;
    height: 3px;
    background: var(--cream);
    border-radius: 2px;
    transition: transform 0.3s, opacity 0.3s;
  }

  .nav-toggle.open span:nth-child(1) { transform: translateY(8px) rotate(45deg); }
  .nav-toggle.open span:nth-child(2) { opacity: 0; }
  .nav-toggle.open span:nth-child(3) { transform: translateY(-8px) rotate(-45deg); }

  @media (max-width: 768px) {
    .nav-toggle { display: flex; }
    .nav-links {
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      flex-direction: column;
      background: var(--brown);
      padding: 0 2rem;
      gap: 0;
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.4s ease, padding 0.4s ease;
    }
    .nav-links.open {
      max-height: 400px;
      padding: 1rem 2rem;
    }
    .nav-links li { padding: 0.75rem 0; }
  }

  /* === Footer === */
  .footer {
    background: var(--brown);
    color: var(--cream);
    padding: 2rem;
    text-align: center;
    margin-top: auto;
  }

  .footer-logo {
    font-family: var(--font-display);
    font-size: 1.3rem;
    color: var(--gold);
    margin-bottom: 0.5rem;
  }

  .footer-copy {
    font-size: 0.85rem;
    opacity: 0.7;
  }

  /* === Shared Utilities === */
  .section {
    padding: 5rem 2rem;
    max-width: 1100px;
    margin: 0 auto;
  }

  .section-title {
    font-size: 2.8rem;
    color: var(--brown);
    text-align: center;
    margin-bottom: 1rem;
  }

  .section-subtitle {
    text-align: center;
    font-size: 1.15rem;
    opacity: 0.7;
    margin-bottom: 3rem;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  .btn {
    display: inline-block;
    padding: 0.85rem 2.2rem;
    font-family: var(--comic);
    font-size: 1.1rem;
    border-radius: 4px;
    border: 3px solid var(--brown);
    cursor: pointer;
    transition: transform 0.2s, box-shadow 0.2s;
    text-transform: uppercase;
    letter-spacing: 2px;
    box-shadow: 4px 4px 0 var(--brown);
  }

  .btn:hover {
    transform: translate(-2px, -2px);
    box-shadow: 6px 6px 0 var(--brown);
  }

  .btn:active {
    transform: translate(2px, 2px);
    box-shadow: 1px 1px 0 var(--brown);
  }

  .btn-primary {
    background: var(--orange);
    color: var(--cream);
  }

  .btn-secondary {
    background: var(--teal);
    color: var(--cream);
  }

  /* Retro decorative divider */
  .divider {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    margin: 3rem auto;
    max-width: 300px;
  }

  .divider::before,
  .divider::after {
    content: '';
    flex: 1;
    height: 3px;
    background: var(--gold);
    border-radius: 2px;
  }

  .divider-icon {
    font-size: 1.5rem;
  }

  /* === Comic Book Styles === */
  .comic-panel {
    border: 4px solid var(--brown);
    border-radius: 4px;
    box-shadow: 6px 6px 0 var(--brown);
    overflow: hidden;
    position: relative;
  }

  .halftone {
    position: relative;
  }

  .halftone::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle, rgba(0,0,0,0.08) 1px, transparent 1px);
    background-size: 6px 6px;
    pointer-events: none;
    z-index: 1;
  }

  .comic-title {
    font-family: var(--comic);
    letter-spacing: 3px;
    text-shadow: 3px 3px 0 rgba(0,0,0,0.25);
  }

  .burst-row {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 1.5rem;
    flex-wrap: wrap;
    padding: 1rem 0;
  }
</style>
